use std
use analyzer
use types
use c

impl Expression {
    fn parse_type_member_expression(context: &Context, inner: &Expression, generics: &Generics) -> &Expression {
        if !context.expect_value(TokenType::Symbol, "::") { return false; }

        match inner.return_type {
            Type::NamespaceCpp(_) => {},
            Type::ClassCpp(_) => {},
            _ => {
                context.error("Unhandled type member expression");
                return 0;
            }
        }

        let member = context.expect(TokenType::Identifier);
        if member == 0 { return 0; }

        let member_type = Expression::get_member_type(context, &inner.return_type, member, true);
        if member_type == 0 { return 0; }

        return Expression::make(context.allocator, member, ExpressionData::MemberStaticExpression(inner, member.value), member_type);
    }

    fn parse_instance_member_expression(context: &Context, inner: &Expression, generics: &Generics) -> &Expression {
        if !context.expect_value(TokenType::Symbol, ".") { return false; }

        let member_name = context.current();
        if member_name == null { return 0; }

        if member_name.type != TokenType::Number && member_name.type != TokenType::Identifier {
            context.error("Unexpected token, expected Identifier or Number");
        }

        context.next_token();

        let member_type = Expression::get_member_type(context, &inner.return_type, member_name, true);
        if member_type == 0 { return 0; }

        let generic_map = inner.return_type.get_generic_map(context);
        let parsed_generics = Array<Type> { allocator: context.allocator, data: 0, length: 0, capacity: 0 };
        let func_info: &Function = 0;

        let is_function = false;
        match member_type {
            Type::Function(func_info2, _) => {
                is_function = true;
                func_info = func_info2;
            },
            Type::FunctionC(_) => { is_function = true; },
            Type::UnknownC(_) => { is_function = true; },
            _ => {},
        }

        if is_function && context.check_value(TokenType::Symbol, "<") {
            parsed_generics = context.parse_generics(generics);
        }

        if is_function && context.check_value(TokenType::Symbol, "(") {
            if !context.expect_value(TokenType::Symbol, "("){ return 0; }

            let arguments = Array<InvokeArgument>::new(context.allocator);

            if func_info != 0 && func_info.parameters.length > 0 && func_info.parameters.data[0].name.value.eq("self") {
                arguments.append(InvokeArgument { name: 0, value: inner });
            }

            while !context.check_value(TokenType::Symbol, ")"){
                let argument = Expression::parse(context, generics);
                if argument == 0 { return 0; }
                arguments.append(InvokeArgument { name: 0, value: argument });

                if !context.check_next(TokenType::Symbol, ",") && !context.check_value(TokenType::Symbol, ")") {
                    context.expect_value(TokenType::Symbol, ")");
                    return 0;
                }
            }

            if !context.expect_value(TokenType::Symbol, ")") { return 0; }

            if func_info != 0 && func_info.generics.array.length > 0 {
                let func_generics = Expression::resolve_function_generics(context, func_info, &parsed_generics, &arguments);
                member_type = context.root.make_type_usage(member_type, &func_generics.array);
            }

            if func_info != 0 && (func_info.type == FunctionType::Builtin || func_info.type == FunctionType::MethodCpp) {
                let member_expression = Expression::make(context.allocator, member_name, ExpressionData::MemberInstanceExpression(inner, member_name.value), member_type);
                return Expression::make_member_function_call(context, member_expression, member_name, member_type, arguments, generic_map);
            } else {
                return Expression::make_type_function_call(context, member_name, member_type, arguments, generic_map);
            }
        } else {
            if generic_map != null {
                member_type = Context::resolve_type(context.allocator, member_type, generic_map, 0);
            }

            return Expression::make(context.allocator, member_name, ExpressionData::MemberInstanceExpression(inner, member_name.value), member_type);
        }
    }

    fn parse_index_expression(context: &Context, inner: &Expression, generics: &Generics) -> &Expression {
        if !context.expect_value(TokenType::Symbol, "[") { return 0; }

        let index_expr = Expression::parse(context, generics);
        if index_expr == 0 { return 0; }

        if !context.expect_value(TokenType::Symbol, "]") { return 0; }

        match index_expr.data {
            ExpressionData::Invoke(target, args) => {
                match target.return_type {
                    Type::Enum(enum_info, _) => {
                        if enum_info.name.value.eq("Range") {
                            let sequence = context.allocator.store(&Sequence {
                                type: SequenceType::Slice,
                                element: *inner.return_type.deref(),
                                element_pointer: inner.return_type,
                            });

                            let start = args.data[0].value;
                            let end = args.data[1].value;

                            let arguments = Array<InvokeArgument>::new(context.allocator);

                            let argument_name_data = context.allocator.store(index_expr.token);
                            argument_name_data.type = TokenType::Identifier;
                            argument_name_data.value = "data";

                            let argument_name_length = context.allocator.store(argument_name_data);
                            argument_name_length.value = "length";

                            if start.is_zero() {
                                arguments.append(InvokeArgument { name: argument_name_data, value: inner });
                                arguments.append(InvokeArgument { name: argument_name_length, value: end });
                            } else {
                                arguments.append(InvokeArgument {
                                    name: argument_name_data,
                                    value: Expression::make(context.allocator, index_expr.token, ExpressionData::BinaryExpression(inner, "+", start), &sequence.element_pointer),
                                });

                                arguments.append(InvokeArgument {
                                    name: argument_name_length,
                                    value: Expression::make(context.allocator, index_expr.token, ExpressionData::BinaryExpression(end, "-", start), &context.root.type_usize),
                                });
                            }

                            let sequence_type = context.allocator.store(&Type::Sequence(sequence));
                            let sequence_expr = Expression::make(context.allocator, index_expr.token, ExpressionData::Type(sequence_type), sequence_type);
                            return Expression::make(context.allocator, index_expr.token, ExpressionData::Invoke(sequence_expr, arguments), sequence_type);
                        }
                    },
                    _ => {},
                }
            },
            _ => {},
        }

        let inner_return_type = &inner.return_type;
        let element_type: &Type = 0;

        if inner_return_type.is_reference_sequence_dynamic() {
            match inner_return_type.deref_1() {
                Type::Sequence(sequence) => {
                    element_type = &sequence.element;
                },
                _ => {},
            }
        } else {
            match inner_return_type {
                Type::Indirect(indirect) => {
                    element_type = &indirect.to;
                },
                Type::Sequence(sequence) => {
                    element_type = &sequence.element;
                },
                _ => {},
            }
        }

        if element_type == 0 && context.module.mode_cpp {
            let unknown_c = context.allocator.store(&UnknownC { include: 0, name: "", generics: Array<Type> { allocator: context.allocator, data: 0, length: 0, capacity: 0 } });
            element_type = Type::UnknownC(unknown_c).to_ptr(context.allocator);
        }

        if element_type == 0 {
            context.error_token(index_expr.token, "Type is not indexable");
            return 0;
        }

        return Expression::make(context.allocator, index_expr.token, ExpressionData::IndexExpression(inner, index_expr), element_type);
    }

    fn parse_postfix(context: &Context, inner: &Expression, generics: &Generics) -> &Expression {
        let token = context.current();

        if token.eq(TokenType::Symbol, ".") {
            return Expression::parse_instance_member_expression(context, inner, generics);
        } else if token.eq(TokenType::Symbol, "::") {
            return Expression::parse_type_member_expression(context, inner, generics);
        } else if token.eq(TokenType::Symbol, "[") {
            return Expression::parse_index_expression(context, inner, generics);
        } else if inner.return_type.resolve_typedef_function().is_function() && (token.eq(TokenType::Symbol, "<") || token.eq(TokenType::Symbol, "(")) {
            match inner.return_type.resolve_typedef_function() {
                Type::Function(func_info, _) => {
                    let parsed_generics = Array<Type> { allocator: context.allocator, data: 0, length: 0, capacity: 0 };

                    if context.check_value(TokenType::Symbol, "<") {
                        parsed_generics = context.parse_generics(generics);
                    }

                    if !context.expect_value(TokenType::Symbol, "(") { return 0; }

                    let arguments = Array<InvokeArgument>::new(context.allocator);

                    while !context.check_value(TokenType::Symbol, ")") {
                        let argument = Expression::parse(context, generics);
                        arguments.append(InvokeArgument { name: 0, value: argument });

                        if !context.check_next(TokenType::Symbol, ",") && !context.check_value(TokenType::Symbol, ")") {
                            context.expect_value(TokenType::Symbol, ")");
                            return 0;
                        }
                    }

                    if !context.expect_value(TokenType::Symbol, ")") { return 0; }

                    if func_info.generics.array.length > 0 {
                        let func_generics = Expression::resolve_function_generics(context, func_info, &parsed_generics, &arguments);
                        inner.return_type = *context.root.make_type_usage(&inner.return_type, &func_generics.array);

                        match inner.data {
                            ExpressionData::Type(&type) => {
                                *type = &inner.return_type;
                            },
                            _ => {},
                        }
                    }

                    if !Expression::validate_arguments(context, token, &inner.return_type, &arguments, null, false) { return 0; }

                    return Expression::make(context.allocator, token, ExpressionData::Invoke(inner, arguments), &func_info.return_type);
                },
                Type::FunctionC(func_info) => {
                    if !context.expect_value(TokenType::Symbol, "(") { return 0; }

                    let arguments = Array<InvokeArgument>::new(context.allocator);

                    while !context.check_value(TokenType::Symbol, ")") {
                        let argument = Expression::parse(context, generics);
                        arguments.append(InvokeArgument { name: 0, value: argument });

                        if !context.check_next(TokenType::Symbol, ",") && !context.check_value(TokenType::Symbol, ")") {
                            context.expect_value(TokenType::Symbol, ")");
                            return 0;
                        }
                    }

                    if !context.expect_value(TokenType::Symbol, ")") { return 0; }

                    return Expression::make(context.allocator, token, ExpressionData::Invoke(inner, arguments), &func_info.return_type);
                },
                Type::ClassCpp(_) => {
                    return Expression::parse_class(context, token, inner, generics);
                },
                Type::UnknownC(_) => {
                    if !context.expect_value(TokenType::Symbol, "(") { return 0; }

                    let arguments = Array<InvokeArgument>::new(context.allocator);

                    while !context.check_value(TokenType::Symbol, ")") {
                        let argument = Expression::parse(context, generics);
                        arguments.append(InvokeArgument { name: 0, value: argument });

                        if !context.check_next(TokenType::Symbol, ",") && !context.check_value(TokenType::Symbol, ")") {
                            context.expect_value(TokenType::Symbol, ")");
                            return 0;
                        }
                    }

                    if !context.expect_value(TokenType::Symbol, ")") { return 0; }

                    return Expression::make(context.allocator, token, ExpressionData::Invoke(inner, arguments), &context.root.type_unknown);
                },
                _ => {
                    context.error_token(token, "Unexpected token when parsing open bracket");
                    return 0;
                },
            }
        }

        return inner;
    }

    fn parse_postfix_chain(context: &Context, inner: &Expression, generics: &Generics) -> &Expression {
        let result = inner;
        while true {
            let next = Expression::parse_postfix(context, result, generics);
            if next == result { break; }
            if next == 0 { return 0; }

            let expanded_token = context.allocator.store(next.token);
            expanded_token.start_line = result.token.start_line;
            expanded_token.start_column = result.token.start_column;
            next.token = expanded_token;

            result = next;
        }
        return result;
    }
}
