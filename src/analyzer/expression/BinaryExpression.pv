use std
use analyzer
use types

impl Expression {
    fn parse_binary(context: &Context, lhs: &Expression, min_prec: usize, generics: &Generics) -> *Expression {
        let result = lhs;

        while true {
            let token = context.current();
            let prec = Expression::get_precedence(token);
            if prec < min_prec { break; }

            let operator = context.expect(TokenType::Symbol);
            if operator == null { return null; }

            let rhs = Expression::parse_primary(context, generics);
            if rhs == null { return null; }

            let rhs_final = Expression::parse_binary(context, rhs, prec + 1, generics);
            if rhs_final == null { return null; }

            let is_arithmetic =
                operator.value.eq("*") || operator.value.eq("+") ||
                operator.value.eq("-") || operator.value.eq("/");

            if is_arithmetic {
                let trait_result = Expression::find_operator_trait_call(context, token, result, &result.return_type, operator.value, rhs_final);
                if trait_result != null {
                    result = trait_result;
                    continue;
                }
            }

            let is_comparison =
                operator.value.eq("==") || operator.value.eq("!=") ||
                operator.value.eq("<=") || operator.value.eq(">=") ||
                operator.value.eq("<")  || operator.value.eq(">")  ||
                operator.value.eq("||") || operator.value.eq("&&");

            let return_type: *Type = null;
            if is_comparison {
                if !operator.value.eq("||") && !operator.value.eq("&&") {
                    if !result.validate_type(context, &rhs_final.return_type, false) { return null; }

                    // Also validate RHS null/0 literal against LHS type (catches `ptr == 0` / `ptr == null`)
                    match rhs_final.data {
                        ExpressionData::NullLiteral => {
                            rhs_final.validate_type(context, &result.return_type, false);
                        },
                        ExpressionData::Literal(value) => {
                            if value.eq("0") {
                                rhs_final.validate_type(context, &result.return_type, false);
                            }
                        },
                        _ => {},
                    }
                }

                return_type = &context.root.type_bool;
            } else {
                return_type = &result.return_type;
            }

            result = Expression::make(context.allocator, token, ExpressionData::BinaryExpression(result, operator.value, rhs_final), return_type);
        }

        return result;
    }

    fn find_operator_trait_call(context: &Context, token: &Token, lhs: &Expression, lhs_type: &Type, operator: str, rhs: &Expression) -> *Expression {
        let trait_name: str = "";
        let func_name: str = "";

        if operator.eq("*") { trait_name = "Mul"; func_name = "mul"; }
        else if operator.eq("+") { trait_name = "Add"; func_name = "add"; }
        else if operator.eq("-") { trait_name = "Sub"; func_name = "sub"; }
        else if operator.eq("/") { trait_name = "Div"; func_name = "div"; }
        else { return null; }

        if lhs_type.is_unknown() || rhs.return_type.is_unknown() { return null; }

        match lhs_type {
            Type::Self => {
                if context.type_self != null {
                    return Expression::find_operator_trait_call(context, token, lhs, context.type_self, operator, rhs);
                }
            },
            // Type::Indirect(indirect) => {
            //     return Expression::find_operator_trait_call(context, token, lhs, &indirect.to, operator, rhs);
            // },
            Type::Struct(struct_info, generic_map) => {
                for *impl_info in struct_info.impls {
                    if !impl_info.has_trait || impl_info.trait_ == null { continue; }
                    if !impl_info.trait_.name.value.eq(trait_name) { continue; }

                    let func = impl_info.functions.find(&func_name);
                    if func == null { continue; }
                    if func.parameters.length < 2 { continue; }

                    let other_param = func.parameters.get(1);
                    if !other_param.type.eq(&rhs.return_type) { continue; }

                    let func_map: *GenericMap = generic_map;
                    if impl_info.typedefs.length > 0 {
                        let aug_map_val = generic_map.clone(context.allocator);
                        let aug_map = context.allocator.store(&aug_map_val);
                        for (name, &typedef_type) in impl_info.typedefs {
                            aug_map.insert(name, *typedef_type);
                        }
                        func_map = aug_map;
                    }

                    let func_type = context.allocator.store(&Type::Function(func, func_map));

                    let arguments = Array<InvokeArgument>::new(context.allocator);
                    arguments.append(InvokeArgument { name: null, value: lhs });
                    arguments.append(InvokeArgument { name: null, value: rhs });

                    return Expression::make_type_function_call(context, token, func_type, arguments, null);
                }
            },
            Type::Primitive(primitive_info) => {
                for *impl_info in primitive_info.impls {
                    if !impl_info.has_trait || impl_info.trait_ == null { continue; }
                    if !impl_info.trait_.name.value.eq(trait_name) { continue; }

                    let func = impl_info.functions.find(&func_name);
                    if func == null { continue; }
                    if func.parameters.length < 2 { continue; }

                    let other_param = func.parameters.get(1);
                    if rhs.return_type.is_self() { continue; }
                    if !other_param.type.eq(&rhs.return_type) { continue; }

                    let func_map: *GenericMap = impl_info.trait_type.get_generic_map(context);

                    let func_type = context.allocator.store(&Type::Function(func, func_map));

                    let arguments = Array<InvokeArgument>::new(context.allocator);
                    arguments.append(InvokeArgument { name: null, value: lhs });
                    arguments.append(InvokeArgument { name: null, value: rhs });

                    return Expression::make_type_function_call(context, token, func_type, arguments, null);
                }
            },
            _ => {},
        }

        return null;
    }

    fn get_precedence(token: &Token) -> usize {
        if token.type != TokenType::Symbol { return 0; }

        if token.value.eq("||") { return 1; }
        if token.value.eq("&&") { return 2; }
        if token.value.eq("|") { return 3; }
        if token.value.eq("^") { return 4; }
        if token.value.eq("&") { return 5; }
        if token.value.eq("==") || token.value.eq("!=") { return 6; }
        if token.value.eq("<")  || token.value.eq(">") || token.value.eq("<=") || token.value.eq(">=")                  { return 7; }
        if token.value.eq("<<") || token.value.eq(">>") { return 8; }
        if token.value.eq("+")  || token.value.eq("-") { return 9; }
        if token.value.eq("*")  || token.value.eq("/") || token.value.eq("%") { return 10; }

        return 0;
    }
}
