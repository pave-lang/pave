#include "stdio.h"
#include "stdlib.h"
#include "fs.h"

use std
use analyzer
use analyzer::expression
use analyzer::statement
use analyzer::types
use analyzer::c

struct Generator {
    allocator: &ArenaAllocator,
    path: *const char,
    root: &Root,
    primitives: HashMap<str, str>,
    primitive_includes: HashMap<str, str>,
    indent: i16,
    code_files: Array<String>,
    error: FileWriter,
    output_line_directives: bool,
    naming_decl: &Naming,
    naming_ident: Naming,
    naming_c99: Naming,
    function_context: &FunctionContext,
}

impl Generator {
    fn overwrite_if_different(&self, file_name: *const char, source: &FILE) -> bool {
        let orig: &FILE = fopen(file_name, "r");
        let different = true;

        if orig != 0 {
            rewind(source);
            let c1: i32 = 0;
            let c2: i32 = 0;
            different = false;
            while !different && (c1 != cast<i32>(EOF)) && (c2 != cast<i32>(EOF)) {
                c1 = fgetc(source);
                c2 = fgetc(orig);
                different = c1 != c2;
            }

            fclose(orig);
        }

        if !different { return false; }

        rewind(source);

        let out: &FILE = fopen(file_name, "w");
        if !out { perror("fopen"); return false; }

        let c: i32 = fgetc(source);
        while c != cast<i32>(EOF) {
            fputc(c, out);
            c = fgetc(source);
        }

        fclose(out);
        return true;
    }

    fn write_indent(&self, file: &FILE) {
        let i: i16 = 0;

        while i < self.indent {
            fprintf(file, "    ");
            i += 1;
        }
    }

    fn write_str(&self, file: &FILE, s: str) -> bool {
        let length: i32 = s.length;
        fprintf(file, "%.*s", length, s.ptr);
        return true;
    }

    fn write_string(&self, file: &FILE, s: &String) -> bool {
        return self.write_str(file, s.as_str());
    }

    fn write_str_title(&self, file: &FILE, s: str) -> bool {
        let i: usize = 0;
        let length = s.length;
        let was_lowercase = false;
        
        while i < length {
            let c: char = s.ptr[i];
            
            if c >= 'a' && c <= 'z' {
                fprintf(file, "%c", c - 32);
                was_lowercase = true;
            } else {
                if was_lowercase && (c >= 'A') && (c <= 'Z') {
                    fprintf(file, "_");
                }

                fprintf(file, "%c", c);
                was_lowercase = false;
            }

            i += 1;
        }

        return true;
    }

    fn write_str_lowercase(&self, file: &FILE, s: str) -> bool {
        let i: usize = 0;
        let length = s.length;

        while i < length {
            let c: char = s.ptr[i];

            if c >= 'A' && c <= 'Z' {
                fprintf(file, "%c", c + 32);
            } else {
                fprintf(file, "%c", c);
            }

            i += 1;
        }

        return true;
    }

    fn write_token(&self, file: &FILE, token: &Token) -> bool {
        return self.write_str(file, token.value);
    }

    fn type_is_discriminated_union(&self, type: &Type, generics: &GenericMap) -> bool {
        match type {
            Type::Indirect(indirect) => { return self.type_is_discriminated_union(&indirect.to, generics); },
            Type::Enum(enum_info, _) => { return enum_info.is_discriminated_union(); },
            Type::Self => { return self.type_is_discriminated_union(generics.self_type, generics); },
            _ => {},
        }

        return false;
    }

    fn write_type(&self, file: &FILE, type: &Type, generics: &GenericMap) -> bool {
        let type_name = self.naming_c99.get_type_name(type, generics.self_type, generics);
        self.write_str(file, type_name.as_str());
        type_name.release();
        return true;
    }

    fn write_type_name(&self, file: &FILE, type: &Type, generics: &GenericMap) -> bool {
        let type_name = self.naming_ident.get_type_name(type, generics.self_type, generics);
        self.write_str(file, type_name.as_str());
        type_name.release();
        return true;
    }

    fn write_variable_decl(&self, file: &FILE, name: str, type: &Type, generics: &GenericMap) -> bool {
        let self_type = type;
        if generics != 0 { self_type = generics.self_type; }

        let variable_decl = self.naming_c99.get_variable_decl(name, type, self_type, generics);
        self.write_str(file, variable_decl.as_str());
        variable_decl.release();
        return true;
    }

    fn write_function_name(&self, file: &FILE, func_info: &Function, generics: &GenericMap) -> bool {
        let name = self.naming_ident.get_type_name(&Type::Function(func_info, generics), generics.self_type, generics);
        defer name.release();

        self.write_str(file, name.as_str());

        return true;
    }

    fn is_reference(type: &Type) -> bool {
        match type {
            Type::Indirect(_) => { return true; },
            Type::TypedefC(info) => { return Generator::is_reference(info.type); },
            _ => { return false; }
        }
    }

    fn is_type_single_value_struct(&self, type: &Type, generics: &GenericMap) -> bool {
        match type.deref() {
            Type::Struct(struct_info, _) => { return struct_info.is_newtype(); },
            Type::Self => { return self.is_type_single_value_struct(generics.self_type, generics); },
            _ => { return false; },
        }
    }

    fn get_function(&self, type: &Type, func_name: str, generic_map: &GenericMap) -> &Function {
        match type {
            Type::Self => { return self.get_function(generic_map.self_type, func_name, generic_map); },
            Type::Indirect(indirect) => { return self.get_function(&indirect.to, func_name, generic_map); },
            Type::Generic(generic) => {
                if generic_map == 0 {
                    fprintf(stderr, "Getting generic for function, but no generic map input\n");
                    return 0;
                }

                let generic_type = generic_map.get(generic.name.value);
                if generic_type == 0 {
                    fprintf(stderr, "Getting generic for function, no item in generic map found\n");
                    return 0;
                }

                return self.get_function(generic_type, func_name, generic_map);
            },
            Type::Primitive(primitive_info) => {
                if primitive_info == 0 {
                    let name_length: i32 = primitive_info.name.length;
                    fprintf(stderr, "Could not find primitive_info %.*s for get_function\n", name_length, primitive_info.name.ptr);
                    return 0;
                }

                let func_info: &Function = 0;

                let impl_iter = primitive_info.impls.iter();
                while func_info == 0 && impl_iter.next() {
                    let impl_info = *impl_iter.value();
                    func_info = impl_info.find_function(func_name);
                }

                if func_info == 0 {
                    let name_length: i32 = primitive_info.name.length;
                    let func_name_length: i32 = func_name.length;
                    fprintf(stderr, "Could not find primitives %.*s function %.*s for get_function\n", name_length, primitive_info.name.ptr, func_name_length, func_name.ptr);
                }

                return func_info;
            },
            Type::Enum(enum_info, _) => {
                if enum_info == 0 {
                    let name_length: i32 = enum_info.name.value.length;
                    fprintf(stderr, "Could not find enum %.*s for get_function\n", name_length, enum_info.name.value.ptr);
                    return 0;
                }

                let func_info: &Function = 0;

                let impl_iter = enum_info.impls.iter();
                while func_info == 0 && impl_iter.next() {
                    let impl_info = *impl_iter.value();
                    func_info = impl_info.find_function(func_name);
                }

                if func_info == 0 {
                    let name_length: i32 = enum_info.name.value.length;
                    let func_name_length: i32 = func_name.length;
                    fprintf(stderr, "Could not find enums %.*s function %.*s for get_function\n", name_length, enum_info.name.value.ptr, func_name_length, func_name.ptr);
                }

                return func_info;
            },
            Type::Struct(struct_info, _) => {
                if struct_info == 0 {
                    let name_length: i32 = struct_info.name.value.length;
                    fprintf(stderr, "Could not find struct %.*s for get_function\n", name_length, struct_info.name.value.ptr);
                    return 0;
                }

                let func_info: &Function = 0;

                for (impl_index, *impl_info) in struct_info.impls.iter().enumerate() {
                    func_info = impl_info.find_function(func_name);

                    if func_info != 0 { break; }

                    func_info = impl_info.trait_.functions.find(&func_name);

                    if func_info != 0 {
                        func_info = self.allocator.store(func_info);
                        func_info.parent = FunctionParent::Struct(struct_info, impl_index, impl_info.trait_);
                        break;
                    }
                }

                if func_info == 0 {
                    let name_length: i32 = struct_info.name.value.length;
                    let func_name_length: i32 = func_name.length;
                    fprintf(stderr, "Could not find structs %.*s function %.*s for get_function\n", name_length, struct_info.name.value.ptr, func_name_length, func_name.ptr);
                }

                return func_info;
            },
            Type::Trait(trait_info, _) => {
                if trait_info == 0 {
                    let name_length: i32 = trait_info.name.value.length;
                    fprintf(stderr, "Could not find trait %.*s for get_function\n", name_length, trait_info.name.value.ptr);
                    return 0;
                }

                let func_info = trait_info.functions.find(&func_name);

                if func_info == 0 {
                    let name_length: i32 = trait_info.name.value.length;
                    let func_name_length: i32 = func_name.length;
                    fprintf(stderr, "Could not find traits %.*s function %.*s for get_function\n", name_length, trait_info.name.value.ptr, func_name_length, func_name.ptr);
                }

                return func_info;
            },
            _ => { 
                fprintf(stderr, "Unhandled type for getting function %s\n", type.name());
            },
        }

        return 0;
    }

    fn write_enum_variant_name(&self, file: &FILE, type: &Type, variant: &EnumVariant) -> bool {
        let parent = variant.parent;
        let name = parent.name;
        self.write_str_title(file, name.value);
        fprintf(file, "__");
        let variant_name = variant.name;
        self.write_str_title(file, variant_name.value);

        return true;
    }

    fn write_deref_if_needed(&self, file: &FILE, type: &Type, generics: &GenericMap) -> bool {
        match type {
            Type::Indirect(indirect) => {
                fprintf(file, "*");
                return Generator::write_deref_if_needed(self, file, &indirect.to, generics);
            },
            Type::TypedefC(info) => {
                return Generator::write_deref_if_needed(self, file, info.type, generics);
            },
            _ => {},
        }

        return true;
    }

    fn write_static_member_accessor(&self, file: &FILE, generics: &GenericMap) -> bool {
        fprintf(file, "::");

        return true;
    }

    fn write_instance_member_accessor(&self, file: &FILE, type: &Type, generics: &GenericMap) -> bool {
        if type.is_fat_pointer() {
            fprintf(file, ".");
            return true;
        }

        match type {
            Type::Indirect(_) => {
                fprintf(file, "->");
            },
            Type::Self => {
                return self.write_instance_member_accessor(file, generics.self_type, generics);
            },
            _ => {
                fprintf(file, ".");
            },
        }

        return true;
    }

    fn write_literal(&self, file: &FILE, type: &Type, value: str) -> bool {
        self.write_str(file, value);

        match type {
            Type::Primitive(primitive_info) => {
                if primitive_info.name.eq("u64") {
                    fprintf(file, "ULL");
                }
            },
            _ => {},
        }

        return true;
    }

    fn write_typeid(&self, file: &FILE, type: &Type, generics: &GenericMap) -> bool {
        let type_name = self.naming_decl.get_type_decl(type, generics.self_type, generics);
        defer type_name.release();

        let type_id = Fnv1a::hash(type_name.array.data, type_name.length());

        fprintf(file, "%zuULL", type_id._0);

        return true;
    }

    fn write_line_directive(&self, file: &FILE, context: &Context, token: &Token) {
        if self.output_line_directives {
            self.write_indent(file);
            fprintf(file, "#line %zu \"", token.start_line + 1);
            self.write_str(file, context.path);
            fprintf(file, "\"\n");
        }
    }

    fn write_str_cast(&self, file: &FILE, inner_expr: &Expression, generics: &GenericMap, reference: bool) {
        if reference { fprintf(file, "&"); }
        fprintf(file, "(struct str){ .ptr = ");
        self.write_expression(file, inner_expr, generics);
        fprintf(file, ", .length = strlen(");
        self.write_expression(file, inner_expr, generics);
        fprintf(file, ") }");
    }

    fn write_trait_cast(&self, file: &FILE, inner_expr: &Expression, type: &Type, generics: &GenericMap) {
        match inner_expr.return_type.deref() {
            Type::Function(func_info, func_generics) => {
                if func_info.type == FunctionType::Coroutine {
                    fprintf(file, "(struct trait_Co_CoroutineStatus) { .vtable = &");

                    match func_info.parent {
                        FunctionParent::Struct(struct_info, _, _) => {
                            self.write_str_title(file, struct_info.name.value);
                            fprintf(file, "__");
                        },
                        _ => {},
                    }
    
                    self.write_str_title(file, func_info.name.value);
                    fprintf(file, "__VTABLE__CO, .instance = &(struct ");
                    self.write_function_name(file, func_info, func_generics);
                    fprintf(file, "__Co_CoroutineStatus__Instance) {}");
                    
                    fprintf(file, " }");
                } else {
                    fprintf(file, "(struct trait_Fn) { .vtable = &");

                    match func_info.parent {
                        FunctionParent::Struct(struct_info, _, _) => {
                            self.write_str_title(file, struct_info.name.value);
                            fprintf(file, "__");
                        },
                        _ => {},
                    }
    
                    self.write_str_title(file, func_info.name.value);
                    fprintf(file, "__VTABLE__DYN_FN, .instance = &(struct ");
                    self.write_function_name(file, func_info, func_generics);
                    fprintf(file, "__Fn__Instance) {}");
                    
                    fprintf(file, " }");
                }

                return;
            },
            _ => {},
        }

        match type {
            Type::Trait(trait_info, _) => {
                fprintf(file, "(");
                self.write_type(file, type, generics);
                fprintf(file, ") { .vtable = &");

                let inner_type = Context::resolve_type(self.allocator, inner_expr.return_type.deref(), generics, 0);
                let inner_type_name = self.naming_ident.get_type_name(inner_type, generics.array.data, generics);
                self.write_str_title(file, inner_type_name.as_str());

                fprintf(file, "__VTABLE__");
                self.write_str_title(file, trait_info.name.value);
                fprintf(file, ", .instance = ");
                self.write_expression(file, inner_expr, generics);
                fprintf(file, " }");
            },
            _ => { self.write_expression(file, inner_expr, generics); },
        }
    }

    fn write_sequence_cast(&self, file: &FILE, inner_expr: &Expression, sequence: &Sequence, generics: &GenericMap) {
        let inner_sequence: &Sequence = 0;

        match inner_expr.return_type {
            Type::Indirect(indirect) => {
                match indirect.to {
                    Type::Sequence(inner_sequence_2) => { inner_sequence = inner_sequence_2; },
                    _ => {},
                }
            },
            _ => {},
        }

        if inner_sequence == 0 {
            fprintf(file, " !!ERROR INVALID SEQUENCE TYPE TO CONVERT INTO SLICE!! ");
            return;
        }

        let length: usize = 0;
        match inner_sequence.type {
            SequenceType::FixedArray(seq_length) => { length = seq_length; },
            _ => {
                fprintf(file, " !!ERROR INVALID SEQUENCE TYPE TO CONVERT INTO SLICE!! ");
                return;
            },
        }

        let sequence_type = Type::Sequence(sequence);

        let name = self.naming_c99.get_type_name(&sequence_type, &sequence_type, generics);
        let unary_inner: &Expression = 0;

        match inner_expr.data {
            ExpressionData::UnaryExpression(expr, inner) => {
                if expr.eq("&") {
                    unary_inner = inner;
                }
            },
            _ => {},
        }

        fprintf(file, "(");
        self.write_string(file, &name);
        fprintf(file, ") { .data = ");

        if unary_inner != 0 {
            self.write_expression(file, unary_inner, generics);
        } else {
            fprintf(file, "*");
            self.write_expression(file, inner_expr, generics);
        }

        fprintf(file, ", .length = %zu }", length);
    }

    fn write_struct_construction(&self, file: &FILE, type: &Type, fields: &Array<InvokeArgument>, generics: &GenericMap) -> bool {
        if self.is_type_single_value_struct(type, generics) {
            if fields.length > 1 {
                fprintf(file, "expected a single field as a value into this struct");
            } else if fields.length == 1 {
                let field = fields.data;
                self.write_expression(file, field.value, generics);
            } else {
                fprintf(file, "0");
            }
        } else {
            let compact = (fields.length <= 1) || (fields.data[0].value.token.start_line == fields.data[fields.length - 1].value.token.start_line);

            fprintf(file, "(");
            self.write_type(file, type, generics);

            if fields.length == 0 {
                fprintf(file, ") {}");
            } else {
                fprintf(file, ") {");
                if !compact { fprintf(file, "\n"); }
            }

            self.indent += 1;
            for (i, field) in fields.iter().enumerate() {
                if compact {
                    if i > 0 { fprintf(file, ", ."); }
                    else { fprintf(file, " ."); }
                } else {
                    self.write_indent(file);
                    fprintf(file, ".");
                }

                self.write_token(file, field.name);
                fprintf(file, " = ");
                self.write_expression(file, field.value, generics);
                if !compact { fprintf(file, ",\n"); }
            }

            self.indent -= 1;

            if fields.length != 0 {
                if compact {
                    fprintf(file, " }");
                } else {
                    self.write_indent(file);
                    fprintf(file, "}");
                }
            }
        }

        return true;
    }

    fn write_enum_variant(&self, file: &FILE, variant: &EnumVariant, type: &Type, arguments: &Array<InvokeArgument>, generics: &GenericMap) -> bool {
        let parent = variant.parent;

        if !parent.is_discriminated_union() {
            self.write_enum_variant_name(file, type, variant);
            return true;
        } 

        fprintf(file, "(");
        self.write_type(file, type, generics);
        fprintf(file, ") { .type = ");
        self.write_enum_variant_name(file, type, variant);

        if arguments == 0 {
            fprintf(file, " }");
            return true;
        }

        if arguments.length > 0 {
            fprintf(file, ", .");
            let name = variant.name;
            self.write_str_lowercase(file, name.value);
            fprintf(file, "_value = ");
        }

        if arguments.length == 1 {
            self.write_expression(file, arguments.data[0].value, generics);
        } else if arguments.length > 1 {
            fprintf(file, "{ ");

            let i: usize = 0;
            for *arg in arguments {
                if i > 0 {
                    fprintf(file, ", ");
                }

                fprintf(file, "._%zu = ", i);

                self.write_expression(file, arg.value, generics);
                i += 1;
            }

            fprintf(file, "}");
        }

        fprintf(file, " }");

        return true;
    }

    fn write_coroutine_invoke(&self, file: &FILE, expression: &Expression, arguments: &Array<InvokeArgument>, generics: &GenericMap) -> bool {
        let data: &ExpressionData = &expression.data;

        match data {
            ExpressionData::Type(type) => {
                match type {
                    Type::Function(func_info, generic_map) => {
                        let resolved_generics = generic_map.resolve_types(self.allocator, generics);

                        fprintf(file, "(struct ");
                        self.write_function_name(file, func_info, &resolved_generics);
                        fprintf(file, ") {");

                        let i: usize = 0;
                        for param in func_info.parameters {
                            if i == 0 {
                                fprintf(file, " .");
                            } else {
                                fprintf(file, ", .");
                            }

                            self.write_token(file, param.name);
                            fprintf(file, " = ");

                            if i < arguments.length {
                                self.write_expression(file, arguments.data[i].value, generics);
                            } else {
                                fprintf(file, "0");
                            }

                            i += 1;
                        }

                        fprintf(file, " }");
                        return true;
                    },
                    _ => {}
                }
            },
            _ => {}
        }

        fprintf(stderr, "coroutine invoke unsupported expression\n");
        return false;
    }

    fn write_builtin_function_invoke(&self, file: &FILE, func_info: &Function, arguments: &Array<InvokeArgument>, func_generics: &GenericMap, generics: &GenericMap) -> bool {
        let name = func_info.name.value;

        if name.eq("typeid") {
            let resolved_generics = func_generics.resolve_types(self.allocator, generics);
            
            let type = resolved_generics.get("T");
            if type == 0 { return false; }

            return self.write_typeid(file, type, generics);
        }

        if name.eq("cast") {
            let resolved_generics = func_generics.resolve_types(self.allocator, generics);

            let arg = arguments.get(0);
            if arg == 0 { return false; }

            let type = resolved_generics.get("T");
            if type == 0 { return false; }

            fprintf(file, "(");
            self.write_type(file, type, generics);
            fprintf(file, ")(");
            self.write_expression(file, arg.value, generics);
            fprintf(file, ")");
            return true;
        }

        self.write_token(file, func_info.name);

        fprintf(file, "(");
        let first = true;
        for arg in arguments {
            if first { first = false; } else { fprintf(file, ", "); }
            self.write_expression(file, arg.value, generics);
        }

        fprintf(file, ")");

        return true;
    }

    fn write_invoke(&self, file: &FILE, expression: &Expression, arguments: &Array<InvokeArgument>, generics: &GenericMap) -> bool {
        let data: &ExpressionData = &expression.data;
        match data {
            ExpressionData::Variable(name) => {
                let success = self.write_str(file, name);
                fprintf(file, "(");

                let first = true;
                for arg in arguments {
                    if first { first = false; } else { fprintf(file, ", "); }
                    success = self.write_expression(file, arg.value, generics) && success;
                }

                fprintf(file, ")");

                return success;
            },
            ExpressionData::MemberStaticExpression(_, _) => {
                let success = self.write_expression(file, expression, generics);
                fprintf(file, "(");

                let first = true;
                for arg in arguments {
                    if first { first = false; } else { fprintf(file, ", "); }
                    success = self.write_expression(file, arg.value, generics) && success;
                }

                fprintf(file, ")");

                return success;
            },
            ExpressionData::MemberInstanceExpression(_, _) => {
                let success = self.write_expression(file, expression, generics);
                fprintf(file, "(");

                let first = true;
                for arg in arguments {
                    if first { first = false; } else { fprintf(file, ", "); }
                    success = self.write_expression(file, arg.value, generics) && success;
                }

                fprintf(file, ")");

                return success;
            },
            ExpressionData::EnumVariant(variant) => {
                return self.write_enum_variant(file, variant, &expression.return_type, arguments, generics);
            },
            ExpressionData::Type(type) => {
                match type {
                    Type::Self => { type = generics.self_type; },
                    _ => {},
                }

                match type.resolve_typedef() {
                    Type::Struct(_, _) => {
                        return self.write_struct_construction(file, type, arguments, generics);
                    },
                    Type::StructC(_) => {
                        return self.write_struct_construction(file, type, arguments, generics);
                    },
                    Type::UnionC(_) => {
                        return self.write_struct_construction(file, type, arguments, generics);
                    },
                    Type::Tuple(_) => {
                        return self.write_struct_construction(file, type, arguments, generics);
                    },
                    Type::Function(func_info, generic_map) => {
                        match func_info.type {
                            FunctionType::Coroutine => {
                                return self.write_coroutine_invoke(file, expression, arguments, generics);
                            },
                            FunctionType::Builtin => {
                                return self.write_builtin_function_invoke(file, func_info, arguments, generic_map, generics);
                            },
                            _ => {},
                        }

                        let name = func_info.name.value;
                        let resolved_generics = generic_map.resolve_types(self.allocator, generics);

                        let args = arguments.iter();
                        let success = true;
                        let first = true;

                        match func_info.parent {
                            FunctionParent::Trait(trait_info) => {
                                if !args.next() {
                                    fprintf(stderr, "Trait function call missing instance argument\n");
                                    return false;
                                }

                                let arg = args.value();

                                if arg.value.return_type.deref().is_trait() {
                                    success = self.write_expression(file, arg.value, generics) && success;
                                    fprintf(file, ".vtable->");
                                    success = self.write_str(file, name) && success;
                                    fprintf(file, "(");
                                    success = self.write_expression(file, arg.value, generics) && success;
                                    fprintf(file, ".instance");

                                    first = false;
                                } else {
                                    let parent_name = self.naming_ident.get_type_name(arg.value.return_type.deref(), generics.self_type, generics);
                                    success = self.write_str(file, parent_name.as_str()) && success;
                                    fprintf(file, "__");

                                    success = self.write_str(file, trait_info.name.value) && success;
                                    fprintf(file, "__");

                                    success = self.write_str(file, func_info.name.value) && success;
                                    fprintf(file, "(");

                                    success = self.write_expression(file, arg.value, generics) && success;

                                    first = false;
                                }

                            },
                            _ => {
                                success = self.write_function_name(file, func_info, &resolved_generics) && success;
                                fprintf(file, "(");
                            },
                        }

                        for arg in args {
                            if first { first = false; } else { fprintf(file, ", "); }
                            success = self.write_expression(file, arg.value, generics) && success;
                        }

                        fprintf(file, ")");

                        return success;
                    },
                    Type::FunctionC(func_info) => {
                        let name = func_info.name;

                        let success = self.write_str(file, name);
                        fprintf(file, "(");

                        let first = true;
                        for arg in arguments {
                            if first { first = false; } else { fprintf(file, ", "); }
                            success = self.write_expression(file, arg.value, generics) && success;
                        }

                        fprintf(file, ")");

                        return success;
                    },
                    Type::Sequence(sequence) => {
                        let success = true;

                        match sequence.type {
                            SequenceType::FixedArray(_) => {
                                fprintf(file, "{");

                                let first = true;
                                for arg in arguments {
                                    if first { first = false; } else { fprintf(file, ", "); }
                                    success = self.write_expression(file, arg.value, generics) && success;
                                }

                                fprintf(file, "}");
                            },
                            SequenceType::Slice => {
                                fprintf(file, "(");
                                self.write_type(file, &expression.return_type, generics);
                                fprintf(file, ") {");

                                let first = true;
                                for arg in arguments {
                                    if first { first = false; fprintf(file, " ."); } else { fprintf(file, ", ."); }
                                    success = self.write_str(file, arg.name.value) && success;
                                    fprintf(file, " = ");
                                    success = self.write_expression(file, arg.value, generics) && success;
                                }

                                fprintf(file, " }"); 
                            },
                        }


                        return success;
                    },
                    Type::ClassCpp(_) => {
                        let success = self.write_type(file, type, generics);
                        let function_mode = (arguments.length > 0) && (arguments.data[0].name == 0);

                        if function_mode {
                            fprintf(file, "(");

                            let first = true;
                            for arg in arguments {
                                if first { first = false; } else { fprintf(file, ", "); }
                                success = self.write_expression(file, arg.value, generics) && success;
                            }

                            fprintf(file, ")");
                        } else {
                            fprintf(file, " {");

                            let first = true;
                            for arg in arguments {
                                if first { first = false; fprintf(file, " ."); } else { fprintf(file, ", ."); }
                                success = self.write_str(file, arg.name.value) && success;
                                fprintf(file, " = ");
                                success = self.write_expression(file, arg.value, generics) && success;
                            }

                            fprintf(file, " }");
                        }

                        return success;
                    },
                    _ => {
                        fprintf(stderr, "Invoke unsupported expression type\n");
                        return false;
                    }
                }
            },
            _ => {},
        }

        fprintf(stderr, "Invoke unsupported expression\n");
        return false;
    }

    fn write_expression(&self, file: &FILE, expression: &Expression, generics: &GenericMap) -> bool {
        let data: &ExpressionData = &expression.data;

        match data {
            ExpressionData::Variable(name) => {
                self.write_variable(file, name);
                return true;
            },
            ExpressionData::Literal(value) => {
                self.write_literal(file, &expression.return_type, value);
                return true;
            },
            ExpressionData::Invoke(target, &arguments) => {
                return self.write_invoke(file, target, arguments, generics);
            },
            ExpressionData::EnumVariant(variant) => {
                return self.write_enum_variant(file, variant, &expression.return_type, 0, generics);
            },
            ExpressionData::UnaryExpression(operator, inner) => {
                let skip_operator = operator.eq("&") && expression.return_type.is_fat_pointer();
                if !skip_operator { self.write_str(file, operator); }
                self.write_expression(file, inner, generics);
                return true;
            },
            ExpressionData::BinaryExpression(left, operator, right) => {
                self.write_expression(file, left, generics);
                fprintf(file, " ");
                self.write_str(file, operator);
                fprintf(file, " ");
                self.write_expression(file, right, generics);
                return true;
            },
            ExpressionData::IfExpression(cond, a, b) => {
                self.write_expression(file, cond, generics);
                fprintf(file, " ? ");
                self.write_expression(file, a, generics);
                fprintf(file, " : ");
                self.write_expression(file, b, generics);
                return true;
            },
            ExpressionData::MemberStaticExpression(parent, member) => {
                self.write_expression(file, parent, generics);
                self.write_static_member_accessor(file, generics);
                self.write_str(file, member);
 
                return true;
            },
            ExpressionData::MemberInstanceExpression(parent, member) => {
                let parent_type = &parent.return_type;

                if self.is_type_single_value_struct(parent_type, generics) {
                    let is_ref = Generator::is_reference(parent_type);
                    if is_ref { fprintf(file, "(*"); }
                    self.write_expression(file, parent, generics);
                    if is_ref { fprintf(file, ")"); }
                    return true;
                }

                match parent_type {
                    Type::Sequence(sequence) => {
                        match sequence.type {
                            SequenceType::FixedArray(length) => {
                                if member.eq("length") {
                                    fprintf(file, "%zu", length);
                                } else {
                                    fprintf(file, "!!ERROR NO MEMBER ");
                                    self.write_str(file, member);
                                    fprintf(file, "!!");
                                }
                            },
                            SequenceType::Slice => {
                                fprintf(file, "!!ERROR TODO MEMBERS FOR DYNAMIC SEQUENCES!!");
                            },
                        }
                    },
                    _ => {
                        self.write_expression(file, parent, generics);
                        self.write_instance_member_accessor(file, &parent.return_type, generics);
                        if member.length > 0 && member.ptr[0] >= '0' && member.ptr[0] <= '9' { fprintf(file, "_"); }
                        self.write_str(file, member);
                    },
                }
 
                return true;
            },
            ExpressionData::Type(type) => {
                self.write_type(file, type, generics);
                return true;
            },
            ExpressionData::IndexExpression(array_expr, index_expr) => {
                self.write_expression(file, array_expr, generics);

                if array_expr.return_type.is_reference_sequence_dynamic() {
                    fprintf(file, ".data");
                }

                fprintf(file, "[");
                self.write_expression(file, index_expr, generics);
                fprintf(file, "]");

                return true;
            },
            ExpressionData::ParenthesizedExpression(expr) => {
                fprintf(file, "(");
                self.write_expression(file, expr, generics);
                fprintf(file, ")");

                return true;
            },
            ExpressionData::CppExpression(cpp_expression) => {
                match cpp_expression {
                    CppExpression::New(placement, new_expression) => {
                        if placement != 0 {
                            fprintf(file, "new(");
                            self.write_expression(file, placement, generics);
                            fprintf(file, ") ");
                        } else {
                            fprintf(file, "new ");
                        }

                        self.write_expression(file, new_expression, generics);
                    },
                    CppExpression::Delete(delete_expression) => {
                        fprintf(file, "delete ");
                        self.write_expression(file, delete_expression, generics);
                    }
                }

                return true;
            },
            ExpressionData::ImplicitCast(inner_expr) => {
                match expression.return_type {
                    Type::Struct(struct_info, _) => {
                        if struct_info.name.value.eq("str") {
                            self.write_str_cast(file, inner_expr, generics, false);
                        }
                    },
                    Type::Indirect(indirect) => {
                        match indirect.to {
                            Type::Struct(struct_info, _) => {
                                if struct_info.name.value.eq("str") {
                                    self.write_str_cast(file, inner_expr, generics, true);
                                } else {
                                    self.write_trait_cast(file, inner_expr, &indirect.to, generics);
                                }
                            },
                            Type::Sequence(sequence) => { self.write_sequence_cast(file, inner_expr, sequence, generics); },
                            _ => { self.write_trait_cast(file, inner_expr, &indirect.to, generics); },
                        }
                    },
                    _ => { self.write_expression(file, inner_expr, generics); },
                }
            },
        }

        return false;
    }

    fn write_defer_statements(&self, file: &FILE, return_type: &Type, defer_statements: &Array<DeferStatement>, generics: &GenericMap) -> bool {
        for defer_info in defer_statements {
            match defer_info {
                DeferStatement::Expression(expression) => {
                    self.write_indent(file);
                    self.write_expression(file, expression, generics);
                    fprintf(file, ";\n");
                },
                DeferStatement::Block(block) => {
                    self.write_indent(file);
                    self.function_context.push_scope(false, false);
                    self.write_block(file, return_type, block, generics, false, false);
                    self.function_context.pop_scope();
                },
            }
        }

        return true;
    }

    fn is_coroutine(&self) -> bool {
        return self.function_context.func_info.type == FunctionType::Coroutine;
    }

    fn write_variable(&self, file: &FILE, name: str) {
        name = self.function_context.get_variable_replacement(name);
        self.write_str(file, name);
    }

    fn write_block(&self, file: &FILE, return_type: &Type, block: &Block, generics: &GenericMap, inline_: bool, no_brackets: bool) -> bool {
        if block == 0 {
            fprintf(file, "{}\n");
            return false;
        }

        if !no_brackets {
            fprintf(file, "{\n");
            self.indent += 1;
        }

        if block.is_top_level_and_has_defer_statements_inside && !return_type.is_void() {
            self.write_indent(file);
            self.write_type(file, return_type, generics);
            fprintf(file, " __result;\n\n");
        }

        let last_statement_is_return = false;

        for statement in block.statements {
            if statement > block.statements.data {
                let prev_statement = statement - 1;

                if prev_statement.last_token.end_line < statement.first_token.start_line - 1 {
                    fprintf(file, "\n");
                }
            }

            self.write_line_directive(file, block.context, statement.first_token);

            last_statement_is_return = false;

            match statement.data {
                StatementData::BlockStatement(child_block) => {
                    self.write_indent(file);
                    self.function_context.push_scope(false, false);
                    if !self.write_block(file, return_type, child_block, generics, false, false) {
                        return false;
                    }
                    self.function_context.pop_scope();
                },
                StatementData::LetStatement(let_statement) => {
                    let name = let_statement.name;
                    let type = let_statement.type;
                    let value = let_statement.value;

                    self.write_indent(file);

                    if !let_statement.is_static {
                        self.function_context.add_variable(name.value, type);
                    }
                    
                    if let_statement.is_static {
                        fprintf(file, "static ");
                    }

                    if self.is_coroutine() {
                        self.write_variable(file, name.value);
                    } else {
                        self.write_variable_decl(file, name.value, type, generics);
                    }

                    if value != 0 {
                        fprintf(file, " = ");
                        self.write_expression(file, value, generics);
                    }

                    fprintf(file, ";\n");
                },
                
                StatementData::YieldStatement(yield_stmt) => {
                    self.function_context.coroutine.yield_count += 1;

                    self.write_indent(file);
                    let yield_number = self.function_context.coroutine.yield_count;
                    fprintf(file, "ctx->_value = ");
                    self.write_expression(file, yield_stmt.expression, generics);
                    fprintf(file, "; ctx->_state = %zu; return true; yield_%zu:\n", yield_number, yield_number);
                },
                StatementData::ReturnStatement(ret) => {
                    let value = ret.expression;
                    let defer_statements = &ret.defer_statements;
                    if value == 0 {
                        self.write_defer_statements(file, return_type, defer_statements, generics);
                        self.write_indent(file);
                        fprintf(file, "return;\n");
                    } else if defer_statements.length > 0 {
                        self.write_indent(file);
                        fprintf(file, "__result = ");
                        self.write_expression(file, value, generics);
                        fprintf(file, ";\n");

                        self.write_defer_statements(file, return_type, defer_statements, generics);

                        self.write_indent(file);
                        fprintf(file, "return __result;\n");
                    } else {
                        self.write_indent(file);
                        fprintf(file, "return ");
                        self.write_expression(file, value, generics);
                        fprintf(file, ";\n");
                    }

                    last_statement_is_return = true;
                },
                StatementData::IfStatement(if_stmt) => {
                    self.write_indent(file);
                    fprintf(file, "if (");
                    self.write_expression(file, if_stmt.expression, generics);
                    fprintf(file, ") ");
                    self.function_context.push_scope(false, false);
                    if !self.write_block(file, return_type, if_stmt.block, generics, true, false) { return false; }
                    self.function_context.pop_scope();

                    for else_statement in if_stmt.else_statements {
                        fprintf(file, " else ");

                        if else_statement.expression != 0 {
                            fprintf(file, "if (");
                            self.write_expression(file, else_statement.expression, generics);
                            fprintf(file, ") ");
                        }

                        self.function_context.push_scope(false, false);
                        if !self.write_block(file, return_type, else_statement.block, generics, true, false) { return false; }
                        self.function_context.pop_scope();
                    }

                    fprintf(file, "\n");
                },
                StatementData::MatchStatement(match_stmt) => {
                    let expression = match_stmt.expression;
                    let cases = &match_stmt.cases;
                    let return_type = &expression.return_type;
                    let is_discriminated_union = self.type_is_discriminated_union(return_type, generics);

                    self.write_indent(file);
                    fprintf(file, "switch (");

                    if !is_discriminated_union {
                        self.write_deref_if_needed(file, return_type, generics);
                    }

                    self.write_expression(file, expression, generics);

                    if is_discriminated_union {
                        self.write_instance_member_accessor(file, return_type, generics);
                        fprintf(file, "type");
                    }

                    fprintf(file, ") {\n");
                    self.indent += 1;

                    for case_info in cases {
                        self.write_line_directive(file, block.context, case_info.first_token);

                        self.write_indent(file);

                        let patterns = &case_info.patterns;
                        for (i, pattern) in patterns.iter().enumerate() {
                            if i > 0 { fprintf(file, "\n"); }

                            match pattern {
                                MatchPattern::StaticValue(expr) => {
                                    fprintf(file, "case ");
                                    self.write_expression(file, expr, generics);
                                    fprintf(file, ":");
                                },
                                MatchPattern::EnumVariant(type, enum_variant, _) => {
                                    fprintf(file, "case ");
                                    self.write_enum_variant_name(file, type, enum_variant);
                                    fprintf(file, ":");
                                },
                                MatchPattern::EnumCValue(enum_variant) => {
                                    fprintf(file, "case ");

                                    let enum_info = enum_variant.parent;
                                    if !enum_info.parent.is_none() {
                                        let type_name = self.naming_decl.get_type_name(&Type::EnumC(enum_info), generics.self_type, generics);
                                        self.write_str(file, type_name.as_str());
                                        type_name.release();
                                        fprintf(file, "::");
                                    }

                                    self.write_str(file, enum_variant.name);
                                    fprintf(file, ":");
                                },
                                MatchPattern::TypeId(&type) => {
                                    fprintf(file, "case ");
                                    self.write_typeid(file, type, generics);
                                    fprintf(file, ":");
                                },
                                MatchPattern::Hash(token) => {
                                    fprintf(file, "case ");
                                    let hash: Hashed;

                                    match token.type {
                                        TokenType::String => {
                                            let value = token.value.slice(1, token.value.length - 1);
                                            hash = value.hash();
                                        },
                                        TokenType::Number => {
                                            let primitive = Expression::number_primitive(token.value);
                                            match primitive.hash() {
                                                hash("f32") => {
                                                    let value: f32 = strtof(token.value.ptr, 0);
                                                    hash = value.hash();
                                                },
                                                hash("f64") => {
                                                    let value: f64 = strtod(token.value.ptr, 0);
                                                    hash = value.hash();
                                                },
                                                hash("u32") => {
                                                    let value: u32 = strtoul(token.value.ptr, 0, 10);
                                                    hash = value.hash();
                                                },
                                                hash("i32") => {
                                                    let value: i32 = strtol(token.value.ptr, 0, 10);
                                                    hash = value.hash();
                                                },
                                                _ => {
                                                    fprintf(stderr, "Hash match pattern on unsupported number literal type\n");
                                                    hash = Hashed(0);
                                                }
                                            }
                                        },
                                        _ => {
                                            fprintf(stderr, "Hash match pattern on unsupported token type\n");
                                            hash = Hashed(0);
                                        }
                                    }

                                    fprintf(file, "%lluULL:", hash._0);
                                },
                                MatchPattern::Default => {
                                    fprintf(file, "default:");
                                },
                            }
                        }
                        
                        fprintf(file, " {\n");
                        self.indent += 1;

                        for pattern in patterns {
                            match pattern {
                                MatchPattern::StaticValue(_) => {},
                                MatchPattern::EnumVariant(_, enum_variant, &parameters) => {
                                    let types = &enum_variant.types;

                                    let param_i: usize = 0;
                                    for param_iter in parameters {
                                        if param_iter.variable.eq(TokenType::Identifier, "_") {
                                            param_i += 1;
                                            continue;
                                        }

                                        let param_type = types.data + param_i;
                                        let variable_expression: &Expression = expression;
                                        let accessor = String::new(self.allocator);

                                        accessor.append_str_lowercase(enum_variant.name.value);
                                        accessor.append("_value");

                                        if types.length > 1 {
                                            accessor.append("._");
                                            accessor.append_usize(param_i);
                                        }

                                        variable_expression = Expression::make(self.allocator, param_iter.variable, ExpressionData::MemberInstanceExpression(variable_expression, accessor.as_str()), param_type);

                                        let name = param_iter.variable;

                                        self.write_line_directive(file, block.context, name);

                                        self.write_indent(file);
                                        self.write_type(file, param_type, generics);
                                        if param_iter.ref { fprintf(file, "*"); }

                                        fprintf(file, " ");

                                        self.write_token(file, name);
                                        fprintf(file, " = ");

                                        if param_iter.ref { fprintf(file, "&"); }
                                        self.write_expression(file, variable_expression, generics);

                                        fprintf(file, ";\n");

                                        param_i += 1;
                                    }
                                },
                                MatchPattern::EnumCValue(_) => {},
                                MatchPattern::TypeId(_) => {},
                                MatchPattern::Hash(_) => {},
                                MatchPattern::Default => {},
                            }
                        }

                        self.function_context.push_scope(true, false);
                        if !self.write_block(file, return_type, case_info.body, generics, true, true) { return false; }
                        self.function_context.pop_scope();

                        self.indent -= 1;
                        self.write_indent(file);
                        fprintf(file, "} break;\n");
                    }

                    self.indent -= 1;
                    self.write_indent(file);
                    fprintf(file, "}\n");
                },
                StatementData::WhileStatement(while_stmt) => {
                    self.write_indent(file);
                    fprintf(file, "while (");
                    self.write_expression(file, while_stmt.expression, generics);
                    fprintf(file, ") ");
                    self.function_context.push_scope(true, true);
                    if !self.write_block(file, return_type, while_stmt.block, generics, false, false) { return false; }
                    self.function_context.pop_scope();
                },
                StatementData::ForStatement(for_statement) => {
                    let is_iterator = false;

                    match for_statement.type {
                        ForStatementType::Range(start, end) => {
                            is_iterator = true;
                            let variable = &for_statement.variables.data[0];
                            let variable_name = variable.name.value;

                            self.write_indent(file);
                            fprintf(file, "for (");

                            self.function_context.add_variable(variable_name, variable.type);
                            
                            if self.is_coroutine() {
                                self.write_variable(file, variable_name);
                            } else {
                                self.write_variable_decl(file, variable_name, variable.type, generics);
                            }

                            fprintf(file, " = ");
                            self.write_expression(file, start, generics);
                            fprintf(file, "; ");
                            self.write_variable(file, variable_name);
                            fprintf(file, " < ");
                            self.write_expression(file, end, generics);
                            fprintf(file, "; ");
                            self.write_variable(file, variable_name);
                            fprintf(file, "++) {");
                            self.indent += 1;
                        },
                        ForStatementType::Sequence(iter_expression) => {
                            is_iterator = true;
                            self.write_indent(file);
                            match for_statement.iter_type.deref() {
                                Type::Sequence(sequence) => {
                                    match sequence.type {
                                        SequenceType::FixedArray(size) => {
                                            fprintf(file, "for (size_t __iter = 0; __iter < %zu; __iter++) {\n", size);
                                        },
                                        SequenceType::Slice => {
                                            fprintf(file, "for (size_t __iter = 0; __iter < ");
                                            self.write_expression(file, iter_expression, generics);
                                            fprintf(file, ".length; __iter++) {\n");
                                        },
                                    }
                                },
                                _ => { fprintf(file, "/* ERROR: Sequence for loop on non-sequence type */"); },
                            }

                            self.indent += 1;

                            let i: usize = 0;
                            for variable in for_statement.variables {
                                if !variable.name.value.eq("_") {
                                    self.write_line_directive(file, block.context, variable.name);

                                    self.write_indent(file);
                                    self.write_type(file, variable.type, generics);
                                    fprintf(file, " ");
                                    self.write_token(file, variable.name);
                                    fprintf(file, " = ");
                                    if variable.ref { fprintf(file, "&"); }
                                    if variable.deref { fprintf(file, "*"); }
                                    match for_statement.iter_type.deref() {
                                        Type::Sequence(sequence) => {
                                            match sequence.type {
                                                SequenceType::FixedArray(_) => {
                                                    self.write_expression(file, iter_expression, generics);
                                                    fprintf(file, "[__iter]");
                                                },
                                                SequenceType::Slice => {
                                                    self.write_expression(file, iter_expression, generics);
                                                    fprintf(file, ".data[__iter]");
                                                },
                                            }
                                        },
                                        _ => { fprintf(file, "/* ERROR */"); },
                                    }

                                    if for_statement.variables.length > 1 {
                                        self.write_instance_member_accessor(file, for_statement.value_type, generics);
                                        fprintf(file, "_%zu", i);
                                    }

                                    fprintf(file, ";\n");
                                }

                                i += 1;
                            }
                        },
                        ForStatementType::Iter(iter_expression) => {
                            is_iterator = for_statement.iter_type.deref().is_iterator();
                            if is_iterator {
                                self.write_indent(file);
                                fprintf(file, "while (");
                                self.write_expression(file, iter_expression, generics);
                                fprintf(file, ".vtable->next(");
                                self.write_expression(file, iter_expression, generics);
                                fprintf(file, ".instance)) {");

                                self.indent += 1;

                                let i: usize = 0;
                                for variable in for_statement.variables {
                                    if !variable.name.value.eq("_") {
                                        self.write_line_directive(file, block.context, variable.name);

                                        self.write_indent(file);
                                        self.write_type(file, variable.type, generics);
                                        fprintf(file, " ");
                                        self.write_token(file, variable.name);
                                        fprintf(file, " = ");
                                        if variable.ref { fprintf(file, "&"); }
                                        if variable.deref { fprintf(file, "*"); }
                                        self.write_expression(file, iter_expression, generics);
                                        fprintf(file, ".vtable->value");
                                        if for_statement.variables.length > 1 { fprintf(file, "_%zu", i); }
                                        fprintf(file, "(");
                                        self.write_expression(file, iter_expression, generics);
                                        fprintf(file, ".instance);\n");
                                    }

                                    i += 1;
                                }
                            } else {
                                let iter_type_name = self.naming_ident.get_type_name(for_statement.iter_type, generics.self_type, generics);

                                self.write_indent(file);
                                fprintf(file, "{ ");
                                self.write_type(file, for_statement.iter_type, generics);
                                fprintf(file, " __iter = ");
                                self.write_expression(file, iter_expression, generics);
                                fprintf(file, ";\n");

                                self.write_line_directive(file, block.context, iter_expression.token);

                                self.write_indent(file);
                                fprintf(file, "while (");
                                self.write_string(file, &iter_type_name);
                                fprintf(file, "__next(&__iter)) {\n");

                                self.indent += 1;

                                let i: usize = 0;
                                for variable in for_statement.variables {
                                    if !variable.name.value.eq("_") {
                                        self.write_line_directive(file, block.context, variable.name);

                                        self.write_indent(file);
                                        self.write_type(file, variable.type, generics);
                                        fprintf(file, " ");
                                        self.write_token(file, variable.name);
                                        fprintf(file, " = ");
                                        if variable.ref { fprintf(file, "&"); }
                                        if variable.deref { fprintf(file, "*"); }
                                        self.write_string(file, &iter_type_name);
                                        fprintf(file, "__value");
                                        if !for_statement.value_type.deref().is_tuple() && for_statement.variables.length > 1 {
                                            fprintf(file, "_%zu", i);
                                        }
                                        fprintf(file, "(&__iter)");

                                        if for_statement.value_type.deref().is_tuple() && for_statement.variables.length > 1 {
                                            self.write_instance_member_accessor(file, for_statement.value_type, generics);
                                            fprintf(file, "_%zu", i);
                                        }

                                        fprintf(file, ";\n");
                                    }

                                    i += 1;
                                }
                            }
                        },
                    }

                    fprintf(file, "\n");

                    self.function_context.push_scope(true, true);
                    if !self.write_block(file, return_type, for_statement.block, generics, false, true) { return false; }
                    self.function_context.pop_scope();

                    self.indent -= 1;
                    self.write_indent(file);
                    if is_iterator {
                        fprintf(file, "}\n");
                    } else {
                        fprintf(file, "} }\n");
                    }
                },
                StatementData::AssignmentStatement(assignment) => {
                    self.write_indent(file);
                    self.write_expression(file, assignment.left, generics);
                    fprintf(file, " ");
                    self.write_str(file, assignment.operator.value);
                    fprintf(file, " ");
                    self.write_expression(file, assignment.right, generics);
                    fprintf(file, ";\n");
                },
                StatementData::ExpressionStatement(expression) => {
                    self.write_indent(file);
                    self.write_expression(file, expression, generics);
                    fprintf(file, ";\n");
                },
                StatementData::ContinueStatement(&defer_statements) => {
                    self.write_defer_statements(file, return_type, defer_statements, generics);
                    self.write_indent(file);
                    fprintf(file, "continue;\n");
                },
                StatementData::BreakStatement(&defer_statements) => {
                    self.write_defer_statements(file, return_type, defer_statements, generics);
                    self.write_indent(file);
                    fprintf(file, "break;\n");
                },
            }
        }

        if !last_statement_is_return {
            self.write_defer_statements(file, return_type, &block.defer_statements, generics);
        }

        if !no_brackets {
            self.indent -= 1;
            self.write_indent(file);

            if inline_ {
                fprintf(file, "}");
            } else {
                fprintf(file, "}\n");
            }
        }

        return true;
    }
    
    fn write_includes_raw(&self, file: &FILE, includes: &HashMap<str, &Include>) {
        for (_, include) in includes {
            let path = include.path;
            if path.length > 0 {
                fprintf(file, "#include <%.*s>\n", cast<i32>(path.length - 2), path.ptr + 1);
            }
        }

        if includes.length > 0 {
            fprintf(file, "\n");
        }
    }

    fn write_impl_includes_raw(&self, file: &FILE, impls: &Array<&Impl>) {
        let written = HashSet<str>::new(self.allocator);
        defer written.release();

        for *impl_info in impls {
            for (_, include) in impl_info.context.module.includes {
                if !written.insert(include.path) { continue; }
                fprintf(file, "#include ");
                self.write_str(file, include.path);
                fprintf(file, "\n");
            }
        }
    }

    fn write_context_primitives(&self, file: &FILE, primitives: &HashSet<str>, exclude_primitives: *HashSet<str>) {
        let includes = HashSet<str>::new(self.allocator);

        for primitive in primitives {
            if exclude_primitives && exclude_primitives.has(primitive) { continue; }
            let include = self.primitive_includes.find(primitive);
            if include == 0 { continue; }
            includes.insert(*include);
        }

        for *include in includes {
            fprintf(file, "#include <%.*s.h>\n", cast<i32>(include.length), include.ptr);
        }

        if includes.length > 0 {
            fprintf(file, "\n");
        }
    }

    fn has_void_self_replacement(parameter: &Parameter, generics: &GenericMap) -> bool {
        if generics == 0 || generics.self_type == 0 { return false; }

        match generics.self_type {
            Type::Primitive(primitive_info) => {
                if primitive_info != 0 && !primitive_info.name.eq("void") {
                    return false;
                }
            },
            _ => { return false; },
        }

        let ref: &Type = 0;

        match parameter.type {
            Type::Indirect(indirect) => {
                ref = &indirect.to;
            },
            _ => { return false; },
        }

        if ref == 0 { return false; }

        match ref {
            Type::Self => { return true; },
            _ => { return false; },
        }
    }

    fn write_function_definition(&self, file: &FILE, func_info: &Function, generics: &GenericMap, custom_name: &String) -> bool {
        self.write_line_directive(file, func_info.context, func_info.name);

        if func_info.type == FunctionType::Coroutine {
            fprintf(file, "bool");
        } else {
            if !self.write_type(file, &func_info.return_type, generics) { return false; }
        }

        fprintf(file, " ");
        if custom_name != 0 {
            self.write_string(file, custom_name);
        } else {
            if func_info.generics.map.length > 0 {
                let name = self.naming_ident.get_type_name(&Type::Function(func_info, generics), generics.self_type, generics);
                self.write_string(file, &name);
            } else {
                if !self.write_function_name(file, func_info, generics) { return false; }
            }
        }

        if func_info.type == FunctionType::Coroutine {
            fprintf(file, "__next(void* _ctx)");
            return true;
        }

        fprintf(file, "(");

        let success = true;
        let first = true;

        for parameter_iter in func_info.parameters {
            if first { first = false; } else { fprintf(file, ", "); }

            if Generator::has_void_self_replacement(parameter_iter, generics) {
                success = self.write_variable_decl(file, "__self", &parameter_iter.type, generics) && success;
            } else {
                success = self.write_variable_decl(file, parameter_iter.name.value, &parameter_iter.type, generics) && success;
            }
        }

        fprintf(file, ")");

        return success;
    }

    fn generate_function_loop(&self, usage: &TypeFunctionUsage) -> bool {
        let success = true;

        for usage_context in usage.usage_contexts {
            success = self.generate_function(usage, usage_context) && success;
        }

        return success;
    }

    fn write_function_block(&self, file: &FILE, name: str, func_info: &Function, generics: &GenericMap, function_usage: &TypeFunctionUsage) -> bool {
        if func_info.type == FunctionType::Coroutine {
            fprintf(file, " {\n");
            self.indent += 1;

            self.write_indent(file);
            fprintf(file, "struct ");
            self.write_function_name(file, func_info, generics);
            fprintf(file, "* ctx = _ctx;\n");

            self.write_indent(file);
            fprintf(file, "switch (ctx->_state) {\n");
            fprintf(file, "case 0: break;\n");
            self.indent += 1;

            for i in 1..function_usage.function_context.coroutine.yield_count + 1 {
                self.write_indent(file);
                fprintf(file, "case %zu: goto yield_%zu;\n", i, i);
            }

            self.write_indent(file);
            fprintf(file, "default: return false;\n");

            self.indent -= 1;
            self.write_indent(file);
            fprintf(file, "}\n\n");

            self.function_context.coroutine.yield_count = 0;
            if !self.write_block(file, &func_info.return_type, func_info.body, generics, false, true) {
                let name_length: u32 = name.length;
                fprintf(stderr, "Failed to write block for %.*s", name_length, name.ptr);
                fclose(file);
                return false;
            }
            
            self.write_indent(file);
            fprintf(file, "ctx->_state = -1; return false;\n");

            self.indent -= 1;
            fprintf(file, "}\n");

            self.write_type(file, &func_info.return_type, generics);
            fprintf(file, " ");
            self.write_function_name(file, func_info, generics);
            fprintf(file, "__value(void* ctx) { return ((struct ");
            self.write_function_name(file, func_info, generics);
            fprintf(file, "*)ctx)->_value; }\n");

            fprintf(file, "struct trait_Iter_");

            let name = self.naming_ident.get_type_name(&func_info.return_type, generics.self_type, generics);
            self.write_string(file, &name);
            name.release();

            fprintf(file, "VTable ");

            match func_info.parent {
                FunctionParent::Struct(struct_info, _, _) => {
                    self.write_str_title(file, struct_info.name.value);
                    fprintf(file, "__");
                },
                _ => {},
            }

            self.write_str_title(file, func_info.name.value);

            fprintf(file, "__VTABLE__ITER = { .next = ");
            self.write_function_name(file, func_info, generics);
            fprintf(file, "__next, .value = ");
            self.write_function_name(file, func_info, generics);
            fprintf(file, "__value };\n\n");

            return true;
        }

        fprintf(file, " ");
        if !self.write_block(file, &func_info.return_type, func_info.body, generics, false, false) {
            let name_length: u32 = name.length;
            fprintf(stderr, "Failed to write block for %.*s", name_length, name.ptr);
            fclose(file);
            return false;
        }

        return true;
    }

    fn write_function_coroutine(&self, file: &FILE, func_info: &Function, generics: &GenericMap) -> bool {
        fprintf(file, "struct ");
        self.write_function_name(file, func_info, generics);
        fprintf(file, " {\n");
        self.indent += 1;
        
        self.write_indent(file);
        fprintf(file, "int32_t _state;\n");

        self.write_indent(file);
        self.write_type(file, &func_info.return_type, generics);
        fprintf(file, " _value;\n\n");

        for (name, type) in self.function_context.coroutine.variables {
            self.write_indent(file);
            self.write_type(file, type, generics);
            fprintf(file, " ");
            self.write_str(file, name);
            fprintf(file, ";\n");
        }

        self.indent -= 1;
        fprintf(file, "};\n\n");

        fprintf(file, "#include <std/trait_Iter_");

        let name = self.naming_ident.get_type_name(&func_info.return_type, generics.self_type, generics);
        self.write_string(file, &name);

        fprintf(file, ".h>\n");

        self.write_type(file, &func_info.return_type, generics);
        fprintf(file, " ");
        self.write_function_name(file, func_info, generics);
        fprintf(file, "__value(void* ctx);\n");

        fprintf(file, "extern struct trait_Iter_");
        self.write_string(file, &name);
        name.release();

        fprintf(file, "VTable ");

        self.write_str_title(file, func_info.name.value);
        fprintf(file, "__VTABLE__ITER;\n");

        return true;
    }

    fn generate_function(&self, usage: &TypeFunctionUsage, usage_context: &UsageContext) -> bool {
        let func_info = usage.type;
        if func_info.type == FunctionType::Builtin { return true; }

        let generics = usage_context.generic_map;
        let include_writer = IncludeWriter::new(self.allocator);

        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);
        let name_str = name.as_str();
        let func_context = FunctionContext::new(self.allocator, func_info, true);
        self.function_context = &func_context;

        let code = self.make_path(func_info.context.module, name_str, ".c");
        let code_file: &FILE = 0;
        let code_tmp: *const char = 0;

        code_tmp = tmpnam(0);
        code_file = fopen(code_tmp, "w+");

        self.code_files.append(code);

        if code_file == 0 { perror(code.c_str()); return false; }

        self.write_context_primitives(code_file, &usage_context.primitive_code, &usage_context.primitive_header);
        self.write_includes_raw(code_file, &func_info.context.module.includes);
        include_writer.write(code_file, self, &usage_context.body, generics, true);

        let header_rel = self.make_rel_path(func_info.context.module, name_str, ".h");
        fprintf(code_file, "#include <");
        self.write_str(code_file, header_rel.as_str());
        fprintf(code_file, ">\n\n");

        if !self.write_function_definition(code_file, func_info, generics, 0) { fclose(code_file); return false; }

        self.write_function_block(code_file, name_str, func_info, generics, usage);

        self.overwrite_if_different(code.c_str(), code_file);
        fclose(code_file);
        remove(code_tmp);

        include_writer = IncludeWriter::new(self.allocator); // TODO fix function definition setup so that we can write headers first, then we only need the initial IncludeWriter

        let header = self.make_path(func_info.context.module, name_str, ".h");
        let header_file: &FILE = 0;
        let header_tmp: *const char = 0;
        header_tmp = tmpnam(0);
        header_file = fopen(header_tmp, "w+");

        if header_file == 0 { perror(header.c_str()); return false; }

        fprintf(header_file, "#ifndef PAVE_");
        self.write_str_title(header_file, name_str);
        fprintf(header_file, "\n#define PAVE_");
        self.write_str_title(header_file, name_str);
        fprintf(header_file, "\n\n");

        self.write_context_primitives(header_file, &usage_context.primitive_code, 0);
        include_writer.write(header_file, self, &usage_context.signature, generics, false);

        if self.is_coroutine() {
            self.write_function_coroutine(header_file, func_info, generics);
        }

        if !self.write_function_definition(header_file, func_info, generics, 0) { fclose(header_file); return false; }
        fprintf(header_file, ";\n");

        fprintf(header_file, "\n#endif\n");

        self.overwrite_if_different(header.c_str(), header_file);
        fclose(header_file);
        remove(header_tmp);

        self.function_context = 0;

        return true;
    }

    fn write_enum_definition(&self, file: &FILE, enum_info: &Enum, usage: &TypeUsage<Enum>, usage_context: &UsageContext, include_writer: &IncludeWriter) -> bool {
        let generics = usage_context.generic_map;
        let enum_name = enum_info.name;
        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);
        let name_length: u32 = name.array.length;
        let is_discriminated_union = enum_info.is_discriminated_union();

        self.write_line_directive(file, enum_info.context, enum_info.name);

        if !is_discriminated_union {
            fprintf(file, "enum ");
            self.write_str(file, enum_name.value);
            fprintf(file, " {\n");
            self.indent += 1;

            for (_, &variant) in enum_info.variants {
                self.write_indent(file);
                self.write_enum_variant_name(file, generics.self_type, variant);

                if variant.value != 0 {
                    fprintf(file, " = ");
                    self.write_expression(file, variant.value, generics);
                }

                fprintf(file, ",\n");
            }

            self.indent -= 1;
            fprintf(file, "};\n");
        } else {
            let has_generics = enum_info.generics.array.length > 0;

            if has_generics {
                fprintf(file, "#ifndef PAVE_");
                self.write_str_title(file, enum_info.name.value);
                self.write_str_title(file, self.naming_ident.enum_generic_type_suffix);
                fprintf(file, "\n#define PAVE_");
                self.write_str_title(file, enum_info.name.value);
                self.write_str_title(file, self.naming_ident.enum_generic_type_suffix);
                fprintf(file, "\n");

                fprintf(file, "enum ");
                self.write_token(file, enum_info.name);
                self.write_str(file, self.naming_ident.enum_generic_type_suffix);
                fprintf(file, " {\n");

                self.indent += 1;

                for (_, &variant) in enum_info.variants {
                    self.write_indent(file);
                    self.write_enum_variant_name(file, generics.self_type, variant);

                    if variant.value != 0 {
                        fprintf(file, " = ");
                        self.write_expression(file, variant.value, generics);
                    }

                    fprintf(file, ",\n");
                }

                self.indent -= 1;
                fprintf(file, "};\n");
                fprintf(file, "#endif\n");
                fprintf(file, "\n");
            }

            fprintf(file, "struct %.*s {\n", name_length, name.array.data);
            self.indent += 1;

            if !has_generics {
                self.write_indent(file);
                fprintf(file, "enum {\n");
                self.indent += 1;

                for (_, &variant) in enum_info.variants {
                    self.write_indent(file);
                    self.write_enum_variant_name(file, generics.self_type, variant);
                    fprintf(file, ",\n");
                }

                self.indent -= 1;
                self.write_indent(file);
                fprintf(file, "} type;\n");
                fprintf(file, "\n");
            } else {
                self.write_indent(file);
                fprintf(file, "enum ");
                self.write_token(file, enum_info.name);
                self.write_str(file, self.naming_ident.enum_generic_type_suffix);
                fprintf(file, " type;\n");
            }

            let variants_with_data: usize = 0;
            for (_, &variant) in enum_info.variants {
                variants_with_data += cast<usize>(variant.types.length > 0);
            }

            if variants_with_data > 1 {
                self.write_indent(file);
                fprintf(file, "union {\n");
                self.indent += 1;
            }

            for (_, &variant) in enum_info.variants {
                if variant.types.length == 1 {
                    self.write_indent(file);
                    self.write_type(file, variant.types.data, generics);
                    fprintf(file, " ");

                    let name = variant.name;
                    self.write_str_lowercase(file, name.value);
                    fprintf(file, "_value;\n");
                } else if variant.types.length > 1 {
                    self.write_indent(file);
                    fprintf(file, "struct { ");

                    for type in variant.types {
                        self.write_type(file, type, generics);
                        fprintf(file, " _%zu; ", type - variant.types.data);
                    }

                    fprintf(file, "} ");
                    let name = variant.name;
                    self.write_str_lowercase(file, name.value);
                    fprintf(file, "_value;\n");
                }
            }

            if variants_with_data > 1 {
                self.indent -= 1;
                self.write_indent(file);
                fprintf(file, "};\n");
            }

            self.indent -= 1;
            fprintf(file, "};\n");
        }

        fprintf(file, "\n");
        include_writer.write(file, self, &usage_context.signature, generics, false);

        for (impl_index, *impl_info) in enum_info.impls.iter().enumerate() {
            let impl_functions_for_impl: &HashMap<usize, TypeFunctionUsage> = 0;
            if usage != 0 { impl_functions_for_impl = usage.impl_functions.get(impl_index); }

            for (_, &func_info) in impl_info.functions {
                let func_ptr = cast<usize>(func_info);
                let function_usage: &TypeFunctionUsage = 0;
                if impl_functions_for_impl != 0 { function_usage = impl_functions_for_impl.find(&func_ptr); }

                if func_info.generics.array.length == 0 {
                    fprintf(file, "\n");
                    if !self.write_function_definition(file, func_info, generics, 0) { return false; }
                    fprintf(file, ";\n");
                }

                if impl_functions_for_impl != 0 && function_usage != 0 {
                    for usage_context in function_usage.usage_contexts {
                        include_writer.write(file, self, &usage_context.signature, usage_context.generic_map, false);
                        usage_context.generic_map.self_type = generics.self_type;
                        fprintf(file, "\n");
                        if !self.write_function_definition(file, func_info, usage_context.generic_map, 0) { return false; }
                        fprintf(file, ";\n");
                    }
                }
            }
        }

        return true;
    }

    fn generate_enum_loop(&self, usage: &TypeUsage<Enum>) -> bool {
        let success = true;

        for usage_context in usage.usage_contexts {
            success = self.generate_enum(usage, usage_context) && success;
        }

        return success;
    }

    fn generate_enum(&self, usage: &TypeUsage<Enum>, usage_context: &UsageContext) -> bool {
        let generics = usage_context.generic_map;
        let enum_info = usage.type;
        let module = enum_info.context.module;
        let include_writer = IncludeWriter::new(self.allocator);

        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);
        let header = self.make_path(module, name.as_str(), ".h");
        let header_tmp: *const char = tmpnam(0);
        let header_file: &FILE = fopen(header_tmp, "w+");
        if header_file == 0 { perror(header.c_str()); return false; }

        fprintf(header_file, "#ifndef PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n#define PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n\n");

        self.write_context_primitives(header_file, &usage_context.primitive_header, 0);
        include_writer.write(header_file, self, &usage_context.layout, generics, false);

        if !self.write_enum_definition(header_file, enum_info, usage, usage_context, &include_writer) { fclose(header_file); return false; }

        fprintf(header_file, "\n#endif\n");

        self.overwrite_if_different(header.c_str(), header_file);
        fclose(header_file);
        remove(header_tmp);

        if enum_info.impls.length == 0 { return true; }

        let code = self.make_path(module, name.as_str(), ".c");
        self.code_files.append(code);

        let code_tmp: *const char = tmpnam(0);
        let code_file: &FILE = fopen(code_tmp, "w+");
        if code_file == 0 { perror(code.c_str()); return false; }

        self.write_context_primitives(code_file, &usage_context.primitive_code, &usage_context.primitive_header);
        self.write_includes_raw(code_file, &module.includes);
        include_writer.write(code_file, self, &usage_context.body, generics, true);

        let header_rel = self.make_rel_path(module, name.as_str(), ".h");
        fprintf(code_file, "#include <");
        self.write_str(code_file, header_rel.as_str());
        fprintf(code_file, ">\n\n");

        if !self.write_impls(code_file, module, &enum_info.impls, &usage.impl_functions, generics, &include_writer) { fclose(code_file); return false; }

        self.overwrite_if_different(code.c_str(), code_file);
        fclose(code_file);
        remove(code_tmp);

        return true;
    }

    fn write_struct_definition(&self, file: &FILE, struct_info: &Struct, usage: &TypeUsage<Struct>, usage_context: &UsageContext) -> bool {
        let generics = usage_context.generic_map;
        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);
        let name_length: i32 = name.array.length;
        let impl_functions = &usage.impl_functions;
        let include_writer = IncludeWriter::new(self.allocator);

        self.write_line_directive(file, &struct_info.module.context, struct_info.name);

        if struct_info.type == StructType::Incomplete {
            fprintf(file, "struct %.*s;\n", name_length, name.array.data);
        } else if struct_info.is_newtype() {
            let field = &struct_info.fields.data[0].value;

            fprintf(file, "typedef ");
            self.write_type(file, &field.type, generics);
            fprintf(file, " %.*s;\n", name_length, name.array.data);
        } else {
            fprintf(file, "struct %.*s {\n", name_length, name.array.data);
            self.indent += 1;

            for (_, &field) in struct_info.fields {
                self.write_indent(file);
                self.write_variable_decl(file, field.name.value, &field.type, generics);
                fprintf(file, ";\n");
            }

            self.indent -= 1;
            fprintf(file, "};\n");
        }

        if usage_context.signature.length > 0 { fprintf(file, "\n"); }
        include_writer.write(file, self, &usage_context.signature, generics, false);

        for (impl_index, *impl_info) in struct_info.impls.iter().enumerate() {
            let trait_info = impl_info.trait_;
            let impl_functions_for_impl: &HashMap<usize, TypeFunctionUsage> = 0;
            if impl_functions != 0 { impl_functions_for_impl = impl_functions.get(impl_index); }

            for (_, &func_info) in impl_info.functions {
                let func_ptr = cast<usize>(func_info);
                let function_usage: &TypeFunctionUsage = 0;
                if impl_functions_for_impl != 0 { function_usage = impl_functions_for_impl.find(&func_ptr); }

                if func_info.generics.array.length == 0 {
                    if trait_info == 0 {
                        if func_info.type == FunctionType::Coroutine && function_usage != 0 {
                            self.function_context = &function_usage.function_context;
                            self.write_function_coroutine(file, func_info, generics);
                            self.function_context = 0;
                        }

                        fprintf(file, "\n");
                        if !self.write_function_definition(file, func_info, generics, 0) { return false; }
                    } else {
                        let generics_void = *generics;
                        generics_void.self_type = &self.root.type_void;

                        let func_name = self.get_trait_function_name(name.as_str(), trait_info, func_info, generics);
                        fprintf(file, "\n");
                        if !self.write_function_definition(file, func_info, &generics_void, &func_name) { return false; }
                    }

                    fprintf(file, ";\n");
                }
                
                if impl_functions_for_impl != 0 {
                    let function_usage = impl_functions_for_impl.find(&func_ptr);
                    if function_usage != 0 {
                        for usage_context in function_usage.usage_contexts {
                            include_writer.write(file, self, &usage_context.signature, usage_context.generic_map, false);

                            // TODO: Test if this is actually needed
                            usage_context.generic_map.self_type = generics.self_type;
                            fprintf(file, "\n");
                            if !self.write_function_definition(file, func_info, usage_context.generic_map, 0) { return false; }
                            fprintf(file, ";\n");
                        }

                        if function_usage.impl_dynamic_function {
                            if func_info.type == FunctionType::Coroutine {
                                fprintf(file, "#include <std/trait_Co_CoroutineStatus.h>\n");
                                fprintf(file, "struct ");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Co_CoroutineStatus__Instance { ");
                                self.indent += 1;
                                for param in func_info.parameters {
                                    self.write_type(file, &param.type, generics);
                                    fprintf(file, " ");
                                    self.write_token(file, param.name);
                                    fprintf(file, "; ");
                                }
                                self.indent -= 1;
                                fprintf(file, "};\n");

                                fprintf(file, "extern struct trait_Co_CoroutineStatusVTable ");
                                self.write_str_title(file, struct_info.name.value);
                                fprintf(file, "__");
                                self.write_str_title(file, func_info.name.value);
                                fprintf(file, "__VTABLE__CO;\n");
                            } else {
                                fprintf(file, "#include <std/trait_Fn.h>\n");
                                fprintf(file, "struct ");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Fn__Instance { ");
                                self.indent += 1;
                                for param in func_info.parameters {
                                    self.write_type(file, &param.type, generics);
                                    fprintf(file, " ");
                                    self.write_token(file, param.name);
                                    fprintf(file, "; ");
                                }
                                self.indent -= 1;
                                fprintf(file, "};\n");

                                fprintf(file, "extern struct trait_FnVTable ");
                                self.write_str_title(file, struct_info.name.value);
                                fprintf(file, "__");
                                self.write_str_title(file, func_info.name.value);
                                fprintf(file, "__VTABLE__DYN_FN;\n");
                            }
                        }
                    }
                }
            }

            if trait_info != 0 {
                for (func_base_name, &func_info) in trait_info.functions {
                    if impl_info.functions.find(&func_base_name) != 0 { continue; }

                    fprintf(file, "\n");
                    let generics_void = *generics;
                    generics_void.self_type = &self.root.type_void;

                    let func_name = self.get_trait_function_name(name.as_str(), trait_info, func_info, generics);
                    if !self.write_function_definition(file, func_info, &generics_void, &func_name) { return false; }
                    fprintf(file, ";\n");
                }
            }
        }

        if struct_info.traits.length > 0 { fprintf(file, "\n"); }

        for (_, trait_entry) in struct_info.traits {
            let trait_info = trait_entry.0;
            fprintf(file, "extern struct ");
            self.write_type_name(file, trait_entry.1, generics);
            fprintf(file, "VTable ");
            self.write_str_title(file, name.as_str());
            fprintf(file, "__VTABLE__");
            self.write_str_title(file, trait_info.name.value);
            fprintf(file, ";\n");
        }

        if usage.impl_dynamic_usage {
            fprintf(file, "#include <std/trait_Struct.h>\n");
            fprintf(file, "extern struct trait_StructVTable ");
            self.write_str_title(file, name.as_str());
            fprintf(file, "__VTABLE__STRUCT;\n");
        }

        return true;
    }

    fn write_impl_definition(&self, file: &FILE, name: str, impl_info: &Impl, generics: &GenericMap) -> bool {
        let trait_info = impl_info.trait_;

        fprintf(file, "\n");

        for (_, &func_info) in impl_info.functions {
            if func_info.generics.array.length == 0 {
                if trait_info == 0 {
                    if !self.write_function_definition(file, func_info, generics, 0) { return false; }
                } else {
                    let generics_void = *generics;
                    generics_void.self_type = &self.root.type_void;

                    let func_name = self.get_trait_function_name(name, trait_info, func_info, generics);
                    if !self.write_function_definition(file, func_info, &generics_void, &func_name) { return false; }
                }

                fprintf(file, ";\n");
            } /* else { TODO } */
        }

        // write_trait_default_implementations
        if trait_info != 0 {
            for (func_base_name, &func_info) in trait_info.functions {
                if impl_info.functions.find(&func_base_name) != 0 { continue; }

                fprintf(file, "\n");
                let generics_void = *generics;
                generics_void.self_type = &self.root.type_void;

                let func_name = self.get_trait_function_name(name, trait_info, func_info, generics);
                if !self.write_function_definition(file, func_info, &generics_void, &func_name) { return false; }
                fprintf(file, ";\n");
            }
        }

        return true;
    }

    fn write_primitive_definition(&self, file: &FILE, primitive_info: &Primitive, generics: &GenericMap) -> bool {
        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);

        for *impl_info in primitive_info.impls {
            self.write_impl_definition(file, name.as_str(), impl_info, generics);
        }

        if primitive_info.traits.length > 0 { fprintf(file, "\n"); }

        for (_, trait_info) in primitive_info.traits {
            fprintf(file, "extern struct trait_");
            self.write_token(file, trait_info.name);
            fprintf(file, "VTable ");
            self.write_str_title(file, name.as_str());
            fprintf(file, "__VTABLE__");
            self.write_str_title(file, trait_info.name.value);
            fprintf(file, ";\n");
        }

        return true;
    }

    fn write_trait_definition(&self, file: &FILE, trait_info: &Trait, generics: &GenericMap) -> bool {
        let void_self_generics = *generics;
        void_self_generics.self_type = &self.root.type_void;

        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);
        let name_length: i32 = name.array.length;

        fprintf(file, "\n");
        self.write_line_directive(file, &trait_info.module.context, trait_info.name);

        fprintf(file, "struct %.*sVTable {\n", name_length, name.array.data);
        self.indent += 1;

        for (_, &func_info) in trait_info.functions {
            if func_info.generics.array.length == 0 {
                let func_name = String::new(self.allocator);
                func_name.append("(*");
                func_name.append(func_info.name.value);
                func_name.append(")");

                self.write_indent(file);
                if !self.write_function_definition(file, func_info, &void_self_generics, &func_name) { return false; }
                fprintf(file, ";\n");
            }
        }

        self.indent -= 1;
        fprintf(file, "};\n\n");

        self.write_line_directive(file, &trait_info.module.context, trait_info.name);

        fprintf(file, "struct %.*s {\n", name_length, name.array.data);
        self.indent += 1;

        self.write_indent(file);
        fprintf(file, "const struct %.*sVTable* vtable;\n", name_length, name.array.data);
        self.write_indent(file);
        fprintf(file, "void* instance;\n");

        self.indent -= 1;
        fprintf(file, "};\n");

        return true;
    }

    fn get_trait_function_name(&self, struct_name: str, trait_info: &Trait, func_info: &Function, generics: &GenericMap) -> String {
        let trait_name = String::new(self.allocator);

        trait_name.append(struct_name);
        trait_name.append("__");
        trait_name.append(trait_info.name.value);
        trait_name.append("__");
        trait_name.append(func_info.name.value);

        return trait_name;
    }

    fn write_impls(&self, file: &FILE, module: &Module, impls: &Array<&Impl>, impl_functions: &Array<HashMap<usize, TypeFunctionUsage>>, generics: &GenericMap, include_writer: &IncludeWriter) -> bool {
        // Deref is for slices
        let name = self.naming_ident.get_type_name(generics.self_type.deref(), generics.self_type, generics);
        let name_length: i32 = name.array.length;
        let path = self.make_rel_path(module, name.as_str(), ".h");

        fprintf(file, "#include <%.*s>\n", cast<i32>(path.array.length), path.array.data);

        for (impl_index, *impl_info) in impls.iter().enumerate() {
            let trait_info = impl_info.trait_;
            let impl_functions_for_impl: &HashMap<usize, TypeFunctionUsage> = 0;
            if impl_functions != 0 { impl_functions_for_impl = impl_functions.get(impl_index); }

            for (_, &func_info) in impl_info.functions {
                let func_ptr = cast<usize>(func_info);
                let function_usage: &TypeFunctionUsage = 0;
                if impl_functions_for_impl != 0 { function_usage = impl_functions_for_impl.find(&func_ptr); }

                if func_info.generics.array.length == 0 {
                    fprintf(file, "\n");
                    if trait_info != 0 {
                        let generics_void = *generics;
                        generics_void.self_type = &self.root.type_void;

                        let func_name = self.get_trait_function_name(name.as_str(), trait_info, func_info, generics);
                        if !self.write_function_definition(file, func_info, &generics_void, &func_name) {
                            let func_name_length: u32 = func_info.name.value.length;
                            fprintf(stderr, "Failed to write definition for %.*s::%.*s\n ", name_length, name.array.data, func_name_length, func_info.name.value.ptr);
                            return false;
                        }

                        fprintf(file, " {\n");
                        self.indent += 1;

                        self.write_indent(file);
                        self.write_type(file, generics.self_type, generics);
                        fprintf(file, "* self = ");

                        if module != 0 && module.mode_cpp {
                            fprintf(file, "(");
                            self.write_type(file, generics.self_type, generics);
                            fprintf(file, "*)");
                        }

                        fprintf(file, "__self");
                        fprintf(file, "; (void)self;\n");

                        let func_context = FunctionContext::new(self.allocator, func_info, true);
                        if function_usage != 0 { func_context.coroutine.yield_count = function_usage.function_context.coroutine.yield_count; }
                        self.function_context = &func_context;

                        if !self.write_block(file, &func_info.return_type, func_info.body, generics, false, true) {
                            let func_name_length: u32 = func_info.name.value.length;
                            fprintf(stderr, "Failed to write block for %.*s::%.*s\n ", name_length, name.array.data, func_name_length, func_info.name.value.ptr);
                            return false;
                        }

                        self.indent -= 1;
                        self.write_indent(file);
                        fprintf(file, "}\n");

                        self.function_context = 0;
                    } else {
                        if !self.write_function_definition(file, func_info, generics, 0) {
                            let func_name_length: u32 = func_info.name.value.length;
                            fprintf(stderr, "Failed to write definition for %.*s::%.*s\n ", name_length, name.array.data, func_name_length, func_info.name.value.ptr);
                            return false;
                        }

                        let func_context = FunctionContext::new(self.allocator, func_info, true);
                        if function_usage != 0 { func_context.coroutine.yield_count = function_usage.function_context.coroutine.yield_count; }
                        self.function_context = &func_context;

                        if !self.write_function_block(file, name.as_str(), func_info, generics, function_usage) {
                            let func_name_length: u32 = func_info.name.value.length;
                            fprintf(stderr, "Failed to write block for %.*s::%.*s\n ", name_length, name.array.data, func_name_length, func_info.name.value.ptr);
                            return false;
                        }

                        let function_usage: &TypeFunctionUsage = 0;
                        if impl_functions_for_impl != 0 { function_usage = impl_functions_for_impl.find(&func_ptr); }

                        if function_usage != 0 && function_usage.impl_dynamic_function {
                            fprintf(file, "\n");
                            if self.is_coroutine() {
                                fprintf(file, "#include <std/trait_Allocator.h>\n");
                            }

                            fprintf(file, "#include <std/Array_TypeId.h>\n");
                            fprintf(file, "struct Array_TypeId* ");
                            self.write_function_name(file, func_info, generics);

                            if self.is_coroutine() {
                                fprintf(file, "__Co__get_params(void* __self) {\n");
                            } else {
                                fprintf(file, "__Fn__get_params(void* __self) {\n");
                            }

                            self.indent += 1;
                            self.write_indent(file);
                            fprintf(file, "static TypeId type_ids[] = { ");

                            let first = true;
                            for param in func_info.parameters {
                                if first { first = false; } else { fprintf(file, ", "); }
                                self.write_typeid(file, &param.type, generics);
                            }

                            fprintf(file, " };\n");
                            self.write_indent(file);
                            fprintf(file, "static struct Array_TypeId result = { .data = type_ids, .length = %zu };\n", func_info.parameters.length);
                            self.write_indent(file);
                            fprintf(file, "return &result;\n");
                            self.indent -= 1;
                            fprintf(file, "}\n");

                            fprintf(file, "bool ");
                            self.write_function_name(file, func_info, generics);

                            if self.is_coroutine() {
                                fprintf(file, "__Co__set_arg(void* __self, uintptr_t index, void* value) {\n");
                            } else {
                                fprintf(file, "__Fn__set_arg(void* __self, uintptr_t index, void* value) {\n");
                            }

                            self.indent += 1;

                            self.write_indent(file);
                            fprintf(file, "struct ");
                            self.write_function_name(file, func_info, generics);

                            if self.is_coroutine() {
                                fprintf(file, "__Co_CoroutineStatus__Instance* self = __self;\n");
                            } else {
                                if module.mode_cpp {
                                    fprintf(file, "__Fn__Instance* self = (struct ");
                                    self.write_function_name(file, func_info, generics);
                                    fprintf(file, "__Fn__Instance*)__self;\n");

                                } else {
                                    fprintf(file, "__Fn__Instance* self = __self;\n");
                                }
                            }

                            self.write_indent(file);
                            fprintf(file, "switch (index) {\n");
                            self.indent += 1;

                            let i: usize = 0;
                            for param in func_info.parameters {
                                self.write_indent(file);
                                fprintf(file, "case %zu: self->", i);
                                self.write_token(file, param.name);
                                fprintf(file, " = ");

                                if !Generator::is_reference(&param.type) {
                                    fprintf(file, "*(");
                                    self.write_type(file, &param.type, generics);
                                    fprintf(file, "*)");
                                } else {
                                    if module.mode_cpp {
                                        fprintf(file, "(");
                                        self.write_type(file, &param.type, generics);
                                        fprintf(file, ")");
                                    }
                                }

                                fprintf(file, "value; return true;\n");
                                i += 1;
                            }

                            self.indent -= 1;
                            self.write_indent(file);
                            fprintf(file, "}\n");

                            self.write_indent(file);
                            fprintf(file, "return false;\n");

                            self.indent -= 1;
                            fprintf(file, "}\n");

                            if self.is_coroutine() {
                                fprintf(file, "struct Iter_CoroutineStatus ");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Co__init(void* __self, struct Allocator allocator) {\n");

                                self.indent += 1;

                                self.write_indent(file);
                                fprintf(file, "struct ");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Co_CoroutineStatus__Instance* self = __self;\n");

                                self.write_indent(file);
                                fprintf(file, "struct ");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "* instance = allocator.vtable->alloc(allocator.instance, sizeof(struct ");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "));\n");

                                for param in func_info.parameters {
                                    self.write_indent(file);
                                    fprintf(file, "instance->");
                                    self.write_token(file, param.name);
                                    fprintf(file, " = ");
                                    fprintf(file, "self->");
                                    self.write_token(file, param.name);
                                    fprintf(file, ";\n");
                                }

                                self.write_indent(file);
                                fprintf(file, "return (struct trait_Iter_CoroutineStatus) { .vtable = &");

                                match func_info.parent {
                                    FunctionParent::Struct(struct_info, _, _) => {
                                        self.write_str_title(file, struct_info.name.value);
                                        fprintf(file, "__");
                                    },
                                    _ => {},
                                }
                                self.write_str_title(file, func_info.name.value);

                                fprintf(file, "__VTABLE__ITER, .instance = instance };\n");

                                self.indent -= 1;
                                fprintf(file, "}\n");
                            } else {
                                fprintf(file, "void ");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Fn__execute(void* __self) {\n");

                                self.indent += 1;

                                self.write_indent(file);
                                fprintf(file, "struct ");
                                self.write_function_name(file, func_info, generics);
                                if module.mode_cpp {
                                    fprintf(file, "__Fn__Instance* self = (struct ");
                                    self.write_function_name(file, func_info, generics);
                                    fprintf(file, "__Fn__Instance*)__self;\n");

                                } else {
                                    fprintf(file, "__Fn__Instance* self = __self;\n");
                                }

                                self.write_indent(file);
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "(");

                                first = true;
                                for param in func_info.parameters {
                                    if first { first = false; } else { fprintf(file, ", "); }
                                    fprintf(file, "self->");
                                    self.write_token(file, param.name);
                                }

                                fprintf(file, ");\n");

                                self.indent -= 1;
                                fprintf(file, "}\n");
                            }

                            if self.is_coroutine() {
                                fprintf(file, "struct trait_Co_CoroutineStatusVTable ");
                            } else {
                                fprintf(file, "struct trait_FnVTable ");
                            }

                            match func_info.parent {
                                FunctionParent::Struct(struct_info, _, _) => {
                                    self.write_str_title(file, struct_info.name.value);
                                    fprintf(file, "__");
                                },
                                _ => {},
                            }
                            self.write_str_title(file, func_info.name.value);

                            if self.is_coroutine() {
                                fprintf(file, "__VTABLE__CO");
                            } else {
                                fprintf(file, "__VTABLE__DYN_FN");
                            }

                            fprintf(file, " = { .get_params = &");
                            self.write_function_name(file, func_info, generics);

                            if self.is_coroutine() {
                                fprintf(file, "__Co__get_params, .set_arg = &");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Co__set_arg, .init = &");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Co__init };\n");
                            } else {
                                fprintf(file, "__Fn__get_params, .set_arg = &");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Fn__set_arg, .execute = &");
                                self.write_function_name(file, func_info, generics);
                                fprintf(file, "__Fn__execute };\n");
                            }
                        }

                        self.function_context = 0;
                    }
                } else if impl_functions_for_impl != 0 {
                    if function_usage != 0 {
                        let func2: &Function = self.allocator.alloc(sizeof(Function));
                        *func2 = *func_info;

                        for usage_context in function_usage.usage_contexts {
                            let generics3 = usage_context.generic_map;

                            // TODO: Is this needed?
                            generics3.self_type = generics.self_type;

                            include_writer.write(file, self, &usage_context.body, generics3, true);
                            fprintf(file, "\n");
                            if !self.write_function_definition(file, func_info, generics3, 0) {
                                let func_name_length: u32 = func_info.name.value.length;
                                fprintf(stderr, "Failed to write definition for %.*s::%.*s\n ", name_length, name.array.data, func_name_length, func_info.name.value.ptr);
                                return false;
                            }

                            let func_context = FunctionContext::new(self.allocator, func_info, true);
                            func_context.coroutine.yield_count = function_usage.function_context.coroutine.yield_count;
                            self.function_context = &func_context;

                            self.write_function_block(file, name.as_str(), func_info, generics3, function_usage);
                            
                            self.function_context = 0;
                        }
                    }
                }
            }

            // write_trait_default_implementations
            if trait_info != 0 {
                for (func_base_name, &func_info) in trait_info.functions {
                    if impl_info.functions.find(&func_base_name) != 0 { continue; }

                    fprintf(file, "\n");
                    let generics_void = *generics;
                    generics_void.self_type = &self.root.type_void;

                    let func_name = self.get_trait_function_name(name.as_str(), trait_info, func_info, generics);
                    if !self.write_function_definition(file, func_info, &generics_void, &func_name) {
                        let func_name_length: u32 = func_info.name.value.length;
                        fprintf(stderr, "Failed to write definition for %.*s::%.*s\n ", name_length, name.array.data, func_name_length, func_info.name.value.ptr);
                        return false;
                    }

                    fprintf(file, " {\n");
                    self.indent += 1;

                    self.write_indent(file);
                    self.write_type(file, generics.self_type, generics);
                    
                    fprintf(file, "* self = ");

                    if module != 0 && module.mode_cpp {
                        fprintf(file, "(");
                        self.write_type(file, generics.self_type, generics);
                        fprintf(file, "*)");
                    }

                    fprintf(file, "__self; (void)self;\n");

                    let func_context = FunctionContext::new(self.allocator, func_info, true);
                    self.function_context = &func_context;

                    if !self.write_block(file, &func_info.return_type, func_info.body, generics, false, true) {
                        let func_name_length: u32 = func_info.name.value.length;
                        fprintf(stderr, "Failed to write block for %.*s::%.*s\n ", name_length, name.array.data, func_name_length, func_info.name.value.ptr);
                        return false;
                    }

                    self.indent -= 1;
                    self.write_indent(file);
                    fprintf(file, "}\n");

                    self.function_context = 0;
                }
            }
        }

        return true;
    }

    fn generate_struct_loop(&self, usage: &TypeUsage<Struct>) -> bool {
        let success = true;

        for usage_context in usage.usage_contexts {
            success = self.generate_struct(usage, usage_context) && success;
        }

        return success;
    }

    fn make_path(&self, module: *Module, name: str, ext: str) -> String {
        let result = self.make_rel_path(module, name, ext);
        result.prepend("/");
        result.prepend(self.path);
        return result;
    }

    fn make_rel_path(&self, module: *Module, name: str, ext: str) -> String {
        let result = String::new(self.allocator);
        let namespace: *Namespace = 0;
        if module != 0 { namespace = module.namespace; }

        while namespace != 0 {
            result.prepend("/");
            result.prepend(namespace.name);
            namespace = namespace.parent;
        }

        result.append(name);
        result.append(ext);

        return result;
    }
        
    fn generate_struct(&self, usage: &TypeUsage<Struct>, usage_context: &UsageContext) -> bool {
        let generics = usage_context.generic_map;
        let struct_info = usage.type;
        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);
        let module = struct_info.module;
        let include_writer = IncludeWriter::new(self.allocator);

        let header = self.make_path(struct_info.module, name.as_str(), ".h");
        let header_tmp: *const char = tmpnam(0);
        let header_file: &FILE = fopen(header_tmp, "w+");
        if header_file == 0 { perror(header.c_str()); return false; }

        fprintf(header_file, "#ifndef PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n#define PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n\n");

        if struct_info.module.mode_cpp || usage_context.cpp_usages.length > 0 {
            fprintf(header_file, "#ifdef __cplusplus\n");

            for (name, type) in usage_context.cpp_usages {
                match type {
                    Type::ClassCpp(class_info) => {
                        if class_info.is_struct {
                            fprintf(header_file, "struct %.*s;\n", cast<i32>(name.length), name.ptr);
                        } else {
                            fprintf(header_file, "class %.*s;\n", cast<i32>(name.length), name.ptr);
                        }
                    },
                    _ => {},
                }
            }

            if struct_info.module.mode_cpp {
                if usage_context.cpp_usages.length > 0 { fprintf(header_file, "\n"); }
                fprintf(header_file, "extern \"C\" {\n");
            }

            fprintf(header_file, "#else\n");

            for (name, _) in usage_context.cpp_usages {
                fprintf(header_file, "typedef struct %.*s %.*s;\n", cast<i32>(name.length), name.ptr, cast<i32>(name.length), name.ptr);
            }

            fprintf(header_file, "#endif\n\n");
        } else if self.root.mode_cpp {
            fprintf(header_file, "#ifdef __cplusplus\n");
            fprintf(header_file, "extern \"C\" {\n");
            fprintf(header_file, "#endif\n\n");
        }

        self.write_context_primitives(header_file, &usage_context.primitive_header, 0);
        include_writer.write(header_file, self, &usage_context.layout, generics, false);
        if usage_context.layout.length > 0 { fprintf(header_file, "\n"); }

        if !self.write_struct_definition(header_file, struct_info, usage, usage_context) { fclose(header_file); return false; }

        if struct_info.module.mode_cpp || self.root.mode_cpp {
            fprintf(header_file, "\n#ifdef __cplusplus\n");
            fprintf(header_file, "}\n");
            fprintf(header_file, "#endif\n");
        }

        fprintf(header_file, "\n#endif\n");

        self.overwrite_if_different(header.c_str(), header_file);
        fclose(header_file);
        remove(header_tmp);

        if struct_info.impls.length == 0 && !usage.impl_dynamic_usage {
            return true;
        }

        let ext: str;
        if struct_info.module.mode_cpp {
            ext = ".cpp";
        } else {
            ext = ".c";
        }

        let code = self.make_path(struct_info.module, name.as_str(), ext);
        self.code_files.append(code);

        let code_tmp: *const char = tmpnam(0);
        let code_file: &FILE = fopen(code_tmp, "w+");
        if code_file == 0 { perror(code.c_str()); return false; }

        self.write_context_primitives(code_file, &usage_context.primitive_code, &usage_context.primitive_header);
        self.write_includes_raw(code_file, &struct_info.module.includes);
        include_writer.write(code_file, self, &usage_context.body, generics, true);

        let header_rel = self.make_rel_path(struct_info.module, name.as_str(), ".h");
        fprintf(code_file, "#include <");
        self.write_str(code_file, header_rel.as_str());
        fprintf(code_file, ">\n\n");

        if !self.write_impls(code_file, struct_info.module, &struct_info.impls, &usage.impl_functions, generics, &include_writer) { fclose(code_file); return false; }

        if struct_info.traits.length > 0 {
            fprintf(code_file, "\n");
        }

        for (_, trait_entry) in struct_info.traits {
            let trait_info = trait_entry.0;
            fprintf(code_file, "struct ");
            self.write_type_name(code_file, trait_entry.1, generics);
            fprintf(code_file, "VTable ");
            self.write_str_title(code_file, name.as_str());
            fprintf(code_file, "__VTABLE__");
            self.write_str_title(code_file, trait_info.name.value);
            fprintf(code_file, " = { ");

            let first = true;
            for (_, &func_info) in trait_info.functions {
                if first { first = false; }
                else { fprintf(code_file, ", "); }

                fprintf(code_file, ".");
                self.write_token(code_file, func_info.name);
                fprintf(code_file, " = &");
                let func_name = self.get_trait_function_name(name.as_str(), trait_info, func_info, generics);
                self.write_string(code_file, &func_name);
            }

            fprintf(code_file, " };\n");
        }

        if usage.impl_dynamic_usage {
            fprintf(code_file, "\n");

            fprintf(code_file, "#include <tuple_usize_str_TypeId.h>\n");
            fprintf(code_file, "#include <slice_tuple_usize_str_TypeId.h>\n");
            fprintf(code_file, "struct slice_tuple_usize_str_TypeId ");
            self.write_string(code_file, &name);
            fprintf(code_file, "__Struct__get_fields(void* __self) {\n");

            self.indent += 1;
            self.write_indent(code_file);
            fprintf(code_file, "static struct tuple_usize_str_TypeId fields[] = { ");

            let field_index: usize = 0;
            for (_, &field) in struct_info.fields {
                if field_index > 0 { fprintf(code_file, ", "); }
                fprintf(code_file, "(struct tuple_usize_str_TypeId){ ._0 = %zu, ._1 = (struct str){ .ptr = \"", field_index);
                self.write_token(code_file, field.name);
                fprintf(code_file, "\", .length = %zu }, ._2 = ", field.name.value.length);
                self.write_typeid(code_file, &field.type, generics);
                fprintf(code_file, " }");
                field_index += 1;
            }

            fprintf(code_file, " };\n");
            self.write_indent(code_file);
            fprintf(code_file, "return (struct slice_tuple_usize_str_TypeId){ .data = fields, .length = %zu };\n", struct_info.fields.length);
            self.indent -= 1;
            fprintf(code_file, "}\n");

            fprintf(code_file, "void* ");
            self.write_string(code_file, &name);

            fprintf(code_file, "__Struct__get_field(void* __self, uintptr_t index) {\n");

            self.indent += 1;

            self.write_indent(code_file);
            self.write_type(code_file, &Type::Self, generics);

            if module.mode_cpp {
                fprintf(code_file, "* self = (");
                self.write_type(code_file, &Type::Self, generics);
                fprintf(code_file, "*)__self;\n");
            } else {
                fprintf(code_file, "* self = __self;\n");
            }

            self.write_indent(code_file);
            fprintf(code_file, "switch (index) {\n");
            self.indent += 1;

            let i: usize = 0;
            for (_, &field) in struct_info.fields {
                self.write_indent(code_file);
                fprintf(code_file, "case %zu: return ", i);

                if struct_info.is_newtype() {
                    fprintf(code_file, "self");
                } else {
                    if !Generator::is_reference(&field.type) || field.type.is_fat_pointer() {
                        fprintf(code_file, "&");
                    }

                    fprintf(code_file, "self->");
                    self.write_token(code_file, field.name);
                }

                fprintf(code_file, ";\n");

                i += 1;
            }

            self.indent -= 1;
            self.write_indent(code_file);
            fprintf(code_file, "}\n");

            self.write_indent(code_file);
            fprintf(code_file, "return 0;\n");

            self.indent -= 1;
            fprintf(code_file, "}\n");

            fprintf(code_file, "bool ");
            self.write_string(code_file, &name);

            fprintf(code_file, "__Struct__set_field(void* __self, uintptr_t index, void* value) {\n");

            self.indent += 1;

            self.write_indent(code_file);
            self.write_type(code_file, &Type::Self, generics);

            if module.mode_cpp {
                fprintf(code_file, "* self = (");
                self.write_type(code_file, &Type::Self, generics);
                fprintf(code_file, "*)__self;\n");
            } else {
                fprintf(code_file, "* self = __self;\n");
            }

            self.write_indent(code_file);
            fprintf(code_file, "switch (index) {\n");
            self.indent += 1;

            i = 0;
            for (_, &field) in struct_info.fields {
                if field.type.is_sequence() { continue; }

                self.write_indent(code_file);

                if struct_info.is_newtype() {
                    fprintf(code_file, "case %zu: *self = *(", i);
                    self.write_type(code_file, &field.type, generics);
                    fprintf(code_file, "*)");
                } else {
                    fprintf(code_file, "case %zu: self->", i);
                    self.write_token(code_file, field.name);
                    fprintf(code_file, " = ");

                    if !Generator::is_reference(&field.type) || field.type.is_fat_pointer() {
                        fprintf(code_file, "*(");
                        self.write_type(code_file, &field.type, generics);
                        fprintf(code_file, "*)");
                    } else if module.mode_cpp {
                        fprintf(code_file, "(");
                        self.write_type(code_file, &field.type, generics);
                        fprintf(code_file, ")");
                    }
                }

                fprintf(code_file, "value; return true;\n");
                i += 1;
            }

            self.indent -= 1;
            self.write_indent(code_file);
            fprintf(code_file, "}\n");

            self.write_indent(code_file);
            fprintf(code_file, "return false;\n");

            self.indent -= 1;
            fprintf(code_file, "}\n");

            fprintf(code_file, "struct trait_StructVTable ");
            self.write_str_title(code_file, name.as_str());
            fprintf(code_file, "__VTABLE__STRUCT");
            fprintf(code_file, " = { .get_fields = &");
            self.write_string(code_file, &name);

            fprintf(code_file, "__Struct__get_fields, .get_field = &");
            self.write_string(code_file, &name);
            fprintf(code_file, "__Struct__get_field, .set_field = &");
            self.write_string(code_file, &name);
            fprintf(code_file, "__Struct__set_field };\n");
        }

        self.overwrite_if_different(code.c_str(), code_file);
        fclose(code_file);
        remove(code_tmp);

        return true;
    }

    fn generate_primitive_loop(&self, usage: &TypeUsage<Primitive>) -> bool {
        let success = true;

        for usage_context in usage.usage_contexts {
            success = self.generate_primitive(usage, usage_context) && success;
        }

        return success;
    }

    fn generate_primitive(&self, usage: &TypeUsage<Primitive>, usage_context: &UsageContext) -> bool {
        let primitive_info = usage.type;
        let generics = usage_context.generic_map;
        let name = primitive_info.name;
        let include_writer = IncludeWriter::new(self.allocator);

        let header = self.make_path(0, name, ".h");
        let header_tmp: *const char = tmpnam(0);
        let header_file: &FILE = fopen(header_tmp, "w+");
        if header_file == 0 { perror(header.c_str()); return false; }

        fprintf(header_file, "#ifndef PAVE_");
        self.write_str_title(header_file, name);
        fprintf(header_file, "\n#define PAVE_");
        self.write_str_title(header_file, name);
        fprintf(header_file, "\n\n");

        self.write_impl_includes_raw(header_file, &primitive_info.impls);
        self.write_context_primitives(header_file, &usage_context.primitive_header, 0);
        include_writer.write(header_file, self, &usage_context.signature, generics, false);

        if !self.write_primitive_definition(header_file, primitive_info, generics) { fclose(header_file); return false; }

        fprintf(header_file, "\n#endif\n");

        self.overwrite_if_different(header.c_str(), header_file);
        fclose(header_file);
        remove(header_tmp);

        if primitive_info.impls.length == 0 {
            return true;
        }

        let code = self.make_path(0, name, ".c");
        self.code_files.append(code);

        let code_tmp: *const char = tmpnam(0);
        let code_file: &FILE = fopen(code_tmp, "w+");
        if code_file == 0 { perror(code.c_str()); return false; }

        self.write_impl_includes_raw(code_file, &primitive_info.impls);
        self.write_context_primitives(code_file, &usage_context.primitive_code, &usage_context.primitive_header);
        include_writer.write(code_file, self, &usage_context.body, generics, true);

        let header_rel = self.make_rel_path(0, name, ".h");
        fprintf(code_file, "#include <");
        self.write_str(code_file, header_rel.as_str());
        fprintf(code_file, ">\n\n");

        if !self.write_impls(code_file, 0, &primitive_info.impls, &usage.impl_functions, generics, &include_writer) { fclose(code_file); return false; }

        for (_, trait_info) in primitive_info.traits {
            fprintf(code_file, "\nstruct trait_");
            self.write_token(code_file, trait_info.name);
            fprintf(code_file, "VTable ");
            self.write_str_title(code_file, name);
            fprintf(code_file, "__VTABLE__");
            self.write_str_title(code_file, trait_info.name.value);
            fprintf(code_file, " = { ");

            let first = true;
            for (_, &func_info) in trait_info.functions {
                if first { first = false; }
                else { fprintf(code_file, ", "); }

                fprintf(code_file, ".");
                self.write_token(code_file, func_info.name);
                fprintf(code_file, " = &");
                let func_name = self.get_trait_function_name(name, trait_info, func_info, generics);
                self.write_string(code_file, &func_name);
            }

            fprintf(code_file, " };\n");
        }

        self.overwrite_if_different(code.c_str(), code_file);
        fclose(code_file);
        remove(code_tmp);

        return true;
    }

    fn generate_sequence(&self, usage: &TypeUsage<Sequence>) -> bool {
        let success = true;

        for usage_context in usage.usage_contexts {
            match usage.type.type {
                SequenceType::Slice => {
                    success = self.generate_slice(usage, usage_context) && success;
                },
                SequenceType::FixedArray(_) => {},
            }
        }

        return success;
    }

    fn generate_slice(&self, usage: &TypeUsage<Sequence>, usage_context: &UsageContext) -> bool {
        let generics = usage_context.generic_map;
        let element_type = &usage.type.element;

        let element_indirect = Indirect { type: IndirectType::Reference, to: *element_type };
        let element_reference_type = Type::Indirect(&element_indirect);

        let sequence_type = Type::Sequence(usage.type);
        let name = self.naming_ident.get_type_name(&sequence_type, &sequence_type, generics);

        let include_writer = IncludeWriter::new(self.allocator);

        let header = self.make_path(0, name.as_str(), ".h");
        let header_tmp: *const char = tmpnam(0);
        let header_file: &FILE = fopen(header_tmp, "w+");
        if header_file == 0 { perror(header.c_str()); return false; }

        fprintf(header_file, "#ifndef PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n#define PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n\n");

        self.write_context_primitives(header_file, &usage_context.primitive_header, 0);
        include_writer.write(header_file, self, &usage_context.layout, generics, false);

        fprintf(header_file, "struct ");
        self.write_string(header_file, &name);
        fprintf(header_file, " { ");

        self.write_variable_decl(header_file, "data", &element_reference_type, generics);
        fprintf(header_file, "; ");
        self.write_variable_decl(header_file, "length", &self.root.type_usize, generics);

        fprintf(header_file, "; };\n");

        self.write_impl_definition(header_file, name.as_str(), self.root.hack_type_impl.impl_info, generics);

        fprintf(header_file, "\n#endif\n");

        self.overwrite_if_different(header.c_str(), header_file);
        fclose(header_file);
        remove(header_tmp);

        let code = self.make_path(0, name.as_str(), ".c");
        self.code_files.append(code);

        let code_tmp: *const char = tmpnam(0);
        let code_file: &FILE = fopen(code_tmp, "w+");
        if code_file == 0 { perror(code.c_str()); return false; }

        let header_rel = self.make_rel_path(0, name.as_str(), ".h");
        fprintf(code_file, "#include <");
        self.write_str(code_file, header_rel.as_str());
        fprintf(code_file, ">\n\n");

        let impls_base = [self.root.hack_type_impl.impl_info];
        let impls = Array<&Impl> { data: impls_base, length: impls_base.length };
        let impl_functions = Array<HashMap<usize, TypeFunctionUsage>> { data: 0, length: 0 };

        if !self.write_impls(code_file, 0, &impls, &impl_functions, generics, &include_writer) { fclose(code_file); return false; }

        self.overwrite_if_different(code.c_str(), code_file);
        fclose(code_file);
        remove(code_tmp);

        return true;
    }

    fn generate_tuple_loop(&self, usage: &TypeUsage<Tuple>) -> bool {
        let success = true;

        for usage_context in usage.usage_contexts {
            success = self.generate_tuple(usage, usage_context) && success;
        }

        return success;
    }

    fn generate_tuple(&self, usage: &TypeUsage<Tuple>, usage_context: &UsageContext) -> bool {
        let generics = usage_context.generic_map;
        let tuple = usage.type;
        let element_types = &tuple.elements;
        let tuple_type = Type::Tuple(tuple);

        let name = self.naming_ident.get_type_name(&tuple_type, &tuple_type, generics);
        let include_writer = IncludeWriter::new(self.allocator);

        let header = self.make_path(0, name.as_str(), ".h");
        let header_tmp: *const char = tmpnam(0);
        let header_file: &FILE = fopen(header_tmp, "w+");
        if header_file == 0 { perror(header.c_str()); return false; }

        fprintf(header_file, "#ifndef PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n#define PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n\n");

        self.write_context_primitives(header_file, &usage_context.primitive_header, 0);
        include_writer.write(header_file, self, &usage_context.layout, generics, false);

        fprintf(header_file, "struct ");
        self.write_string(header_file, &name);
        fprintf(header_file, " {\n");
        self.indent += 1;

        for (i, element) in element_types.iter().enumerate() {
            let element_name = String::new(self.allocator);
            element_name.append("_");
            element_name.append_usize(i);

            self.write_indent(header_file);
            self.write_variable_decl(header_file, element_name.as_str(), element, generics);

            fprintf(header_file, ";\n");

            element_name.release();
        }

        self.indent -= 1;
        fprintf(header_file, "};\n");

        fprintf(header_file, "\n#endif\n");

        self.overwrite_if_different(header.c_str(), header_file);
        fclose(header_file);
        remove(header_tmp);

        return true;
    }

    fn generate_trait_loop(&self, usage: &TypeUsage<Trait>) -> bool {
        let success = true;

        for usage_context in usage.usage_contexts {
            success = self.generate_trait(usage, usage_context) && success;
        }

        return success;
    }

    fn generate_trait(&self, usage: &TypeUsage<Trait>, usage_context: &UsageContext) -> bool {
        let generics = usage_context.generic_map;
        let trait_info = usage.type;

        let name = self.naming_ident.get_type_name(generics.self_type, generics.self_type, generics);
        let header = self.make_path(trait_info.module, name.as_str(), ".h");
        let include_writer = IncludeWriter::new(self.allocator);

        let header_tmp: *const char = tmpnam(0);
        let header_file: &FILE = fopen(header_tmp, "w+");
        if header_file == 0 { perror(header.c_str()); return false; }

        fprintf(header_file, "#ifndef PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n#define PAVE_");
        self.write_str_title(header_file, name.as_str());
        fprintf(header_file, "\n\n");

        if trait_info.module.mode_cpp {
            fprintf(header_file, "#ifdef __cplusplus\n");
            fprintf(header_file, "extern \"C\" {\n");
            fprintf(header_file, "#endif\n\n");
        }

        self.write_context_primitives(header_file, &usage_context.primitive_header, 0);
        include_writer.write(header_file, self, &usage_context.signature, generics, false);

        if !self.write_trait_definition(header_file, trait_info, generics) { fclose(header_file); return false; }

        if trait_info.module.mode_cpp {
            fprintf(header_file, "\n#ifdef __cplusplus\n");
            fprintf(header_file, "}\n");
            fprintf(header_file, "#endif\n");
        }

        fprintf(header_file, "\n#endif\n");

        self.overwrite_if_different(header.c_str(), header_file);
        fclose(header_file);
        remove(header_tmp);

        return true;
    }

    fn create_directories(&self, base_path: str, children: &HashMap<str, &Namespace>) {
        for (name, namespace) in children {
            let path = String::new(self.allocator);
            path.append(base_path);
            path.append("/");
            path.append(name);
            create_directory(path.c_str());

            self.create_directories(path.as_str(), &namespace.children);
        }
    }

    fn generate(allocator: &ArenaAllocator, path: *const char, output_line_directives: bool, output_seperator: *const char, root: &Root) -> bool {
        let result = true;

        let self: Generator = Generator {
            allocator,
            path,
            root,
            primitives: HashMap<str, str>::new(allocator),
            primitive_includes: HashMap<str, str>::new(allocator),
            code_files: Array<String>::new(allocator),
            error: FileWriter::new(stderr),
            output_line_directives,
            naming_decl: &root.naming_decl,
            naming_ident: Naming::new_ident(allocator),
        };

        self.naming_c99 = Naming::new_c99(allocator, &self.naming_ident);

        let primitives: &HashMap<str, str> = &self.primitives;
        primitives.insert("bool", "bool");
        primitives.insert("i8", "int8_t");
        primitives.insert("i16", "int16_t");
        primitives.insert("i32", "int32_t");
        primitives.insert("i64", "int64_t");
        primitives.insert("isize", "intptr_t");
        primitives.insert("u8", "uint8_t");
        primitives.insert("u16", "uint16_t");
        primitives.insert("u32", "uint32_t");
        primitives.insert("u64", "uint64_t");
        primitives.insert("usize", "uintptr_t");
        primitives.insert("f32", "float");
        primitives.insert("f64", "double");
        primitives.insert("char", "char");
        primitives.insert("void", "void");

        let primitive_includes: &HashMap<str, str> = &self.primitive_includes;
        primitive_includes.insert("i8", "stdint");
        primitive_includes.insert("u8", "stdint");
        primitive_includes.insert("i16", "stdint");
        primitive_includes.insert("u16", "stdint");
        primitive_includes.insert("i32", "stdint");
        primitive_includes.insert("u32", "stdint");
        primitive_includes.insert("i64", "stdint");
        primitive_includes.insert("u64", "stdint");
        primitive_includes.insert("isize", "stdint");
        primitive_includes.insert("usize", "stdint");
        primitive_includes.insert("bool", "stdbool");
        primitive_includes.insert("str", "string");

        self.create_directories(path, &root.children);

        let usages = Usages::new(&self);
        for (_, &usage) in usages.primitives { self.generate_primitive_loop(usage); }
        for (_, &usage) in usages.structs { self.generate_struct_loop(usage); }
        for (_, &usage) in usages.enums { self.generate_enum_loop(usage); }
        for (_, &usage) in usages.traits { self.generate_trait_loop(usage); }
        for (_, &usage) in usages.functions { self.generate_function_loop(usage); }
        for (_, &usage) in usages.sequences { self.generate_sequence(usage); }
        for (_, &usage) in usages.tuples { self.generate_tuple_loop(usage); }

        if self.code_files.length > 0 {
            let command = String::new(self.allocator);

            for code_file in self.code_files {
                if command.array.length > 0 {
                    command.append(output_seperator);
                }

                command.append(code_file.as_str());
            }

            let length: u32 = command.array.length;
            printf("%.*s\n", length, command.array.data);
        }

        return result;
    }
}
