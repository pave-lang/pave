enum Range<T> {
    All,
    Start(T),
    End(T),
    StartEnd(T, T),
}

impl<T> Range<T> {
    // fn start(self) -> T {
    //     match self {
    //         Range<T>::Start(start) => { return start; },
    //         Range<T>::StartEnd(start, _) => { return start; },
    //         _ => { return cast<T>(0); }
    //     } 
    // }

    // fn end(self, actual_end: T) -> T {
    //     match self {
    //         Range<T>::End(end) => { return end; },
    //         Range<T>::StartEnd(_, end) => { return end; },
    //         _ => { return actual_end; }
    //     } 
    // }

    fn iter(self) -> Iter<T> {
        match self {
            Range<T>::End(end) => { return Iter<T>::new(cast<T>(0), end); },
            Range<T>::StartEnd(start, end) => { return Iter<T>::new(start, end); },
            _ => { return Iter<T> { step: 0, iter: cast<T>(0), start: cast<T>(0), end: cast<T>(0) }; }
        }
    }
}
