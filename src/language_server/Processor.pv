#include "pipes.h"

use std
use analyzer

struct Processor {
    allocator: &ArenaAllocator,
    pipe_read: pipe_t,
    pipe_write: pipe_t,
}

impl Processor {
    fn new(allocator: &ArenaAllocator, pipe_read: pipe_t, pipe_write: pipe_t) -> Self {
        return Self {
            allocator,
            pipe_read,
            pipe_write,
        };
    }

    fn read_headers(&self, content_length: &usize) -> bool {
        let MAX_LENGTH: usize = 1024;
        let buf: *char = self.allocator.alloc(1024);
        defer self.allocator.free(buf);
        let pipe = self.pipe_read;

        let pos: usize = 0;
        let c: char = 0;
        let newlines: usize = 0;
        while pos < MAX_LENGTH - 1 {
            if read_pipe(pipe, &c, 1) == 0 { return false; }

            buf[pos] = c;
            pos += 1;
            
            if c == '\n' {
                newlines += 1;
                if newlines == 2 && pos >= 4 && buf[pos-4] == '\r' && buf[pos-3] == '\n' && buf[pos-2] == '\r' && buf[pos-1] == '\n' {
                    buf[pos] = '\0';
                    
                    let cl = strstr(buf, "Content-Length:");
                    if cl != null { *content_length = strtoul(cl + 15, 0, 10); }

                    return true;
                }
            } else if c != '\r' {
                newlines = 0;
            }
      }

      return false;
    }

    fn read_message(&self) -> String {
        let content_length: usize = 0;
        if !self.read_headers(&content_length) { return String::new(self.allocator); }

        let content = String::new(self.allocator);
        content.ensure_can_hold(content_length);

        content.array.length = content_length;
        if read_pipe(self.pipe_read, content.array.data, content_length) == 0 { return String::new(self.allocator); }

        fprintf(stderr, "Receved: %s\n\n", content.c_str());

        return content;
    }

    fn send_message(&self, method: *const char, params: JsonNode) {
        let response = HashMap<str, JsonNode>::new(self.allocator);
        response.insert("jsonrpc", JsonNode::String("2.0"));
        response.insert("method", JsonNode::String(method));
        response.insert("params", params);
        
        let text = JsonNode::Object(response).to_string(self.allocator);
        self.send_response_text(text.as_str());
    }

    fn send_message_no_params(&self, method: *const char) {
        let response = HashMap<str, JsonNode>::new(self.allocator);
        response.insert("jsonrpc", JsonNode::String("2.0"));
        response.insert("method", JsonNode::String(method));
        
        let text = JsonNode::Object(response).to_string(self.allocator);
        self.send_response_text(text.as_str());
    }

