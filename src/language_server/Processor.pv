    //     self.send_response_text(text.as_str());
    // }

    fn send_response(&self, id: f64, result: JsonNode) {
        let response = HashMap<str, JsonNode>::new(self.allocator);
        response.insert("jsonrpc", JsonNode::String("2.0"));
        response.insert("id", JsonNode::Number(id));
        response.insert("result", result);
        
        let text = JsonNode::Object(response).to_string(self.allocator);
        self.send_response_text(text.as_str());
    }

    fn send_response_text(&self, string: str) {
        let header: *char = self.allocator.alloc(128);
        defer self.allocator.free(header);

        let header_len: usize = snprintf(header, 128, "Content-Length: %zu\r\n\r\n", string.length);

        write_pipe(self.pipe_write, header, header_len);
        write_pipe(self.pipe_write, string.ptr, string.length);

        fprintf(stderr, "Sent: %s\n\n", string.ptr);
    }

    fn initialize(&self, params: &JsonNode) -> JsonNode {
        let result = HashMap<str, JsonNode>::new(self.allocator);

        let capabilities = HashMap<str, JsonNode>::new(self.allocator);

        let text_document_sync = HashMap<str, JsonNode>::new(self.allocator);
        text_document_sync.insert("openClose", JsonNode::Boolean(true));
        text_document_sync.insert("change", JsonNode::Number(2));
    
        let save = HashMap<str, JsonNode>::new(self.allocator);
        save.insert("includeText", JsonNode::Boolean(false));
        text_document_sync.insert("save", JsonNode::Object(save));

        capabilities.insert("textDocumentSync", JsonNode::Object(text_document_sync));

        let inlay_hint_provider = HashMap<str, JsonNode>::new(self.allocator);
        inlay_hint_provider.insert("resolveProvider", JsonNode::Boolean(false));
        capabilities.insert("inlayHintProvider", JsonNode::Object(inlay_hint_provider));

        let has_workspace_folder_capability = true;
        if has_workspace_folder_capability {
            let workspace = HashMap<str, JsonNode>::new(self.allocator);
            let workspace_folders = HashMap<str, JsonNode>::new(self.allocator);
            workspace_folders.insert("supported", JsonNode::Boolean(true));
            workspace.insert("workspaceFolders", JsonNode::Object(workspace_folders));
            capabilities.insert("workspace", JsonNode::Object(workspace));
        }

        result.insert("capabilities", JsonNode::Object(capabilities));

        return JsonNode::Object(result);
    }

